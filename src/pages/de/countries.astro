---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CountryGrid from '../../components/CountryGrid.astro';
import { supabase } from '../../lib/supabaseClient';

// Fetch active countries
const { data: countriesRaw } = await supabase
  .from('countries')
  .select('id, slug, name_en, name_de, card_description_en, card_description_de, flag_emoji')
  .eq('is_active', true)
  .order('order_index', { ascending: true, nullsFirst: false })
  .order('name_en', { ascending: true });

// Fetch vendor counts from the same view the country detail pages use
const { data: countRows } = await supabase
  .from('country_vendor_counts')
  .select('country, vendor_count');

const countMap = new Map<string, number>();
(countRows || []).forEach((row: any) => {
  if (row.country) countMap.set(row.country.toLowerCase(), row.vendor_count || 0);
});

const countries = (countriesRaw || []).map((c) => ({
  slug: c.slug,
  name: c.name_de || c.name_en,
  card_description_en: c.card_description_en,
  card_description_de: c.card_description_de,
  flag_emoji: c.flag_emoji,
  vendor_count: countMap.get((c.name_en || '').toLowerCase()) || 0,
}))
  .filter((c) => (c.vendor_count || 0) > 0)
  .sort((a, b) => {
    if ((b.vendor_count || 0) !== (a.vendor_count || 0)) {
      return (b.vendor_count || 0) - (a.vendor_count || 0);
    }
    return (a.name || '').localeCompare(b.name || '');
  });

const description = "Die europaeische Industrieautomatisierungslandschaft wird von regionalen Staerken gepraegt - von der Schweizer Praezisionsfertigungstradition ueber das tiefe MES- und SCADA-Oekosystem Deutschlands bis hin zur nordischen Vorreiterrolle in Robotik und Digitalisierung. Die Wahl des richtigen Automatisierungspartners haengt oft von geografischer Naehe, lokaler Sprachkompetenz und Kenntnis regionaler Regularien ab - sei es die EU-Maschinenrichtlinie, GMP-Anforderungen in der Pharmabranche oder Lebensmittelsicherheitsstandards wie IFS und BRC. Ein Anbieter mit Sitz in Ihrer Region kennt lokale Lieferketten, bietet Vor-Ort-Support und bewegt sich sicher im regulatorischen Umfeld. Durchsuchen Sie Automatisierungsanbieter nach Land und finden Sie Systemintegratoren, MES-Spezialisten, SCADA-Anbieter, Robotik-Integratoren und Schaltschrankbauer mit nachgewiesener Kompetenz in Ihrer Region. Jede Laenderseite zeigt verifizierte Anbieter, filterbar nach Kategorie, Technologie und Branche.";

const breadcrumbs = [
  { label: 'Startseite', href: '/de/' },
  { label: 'Länder', href: '/de/countries' },
];
---

<BaseLayout
  title="Automatisierungsanbieter nach Land | Automation List"
  description={description}
  lang="de"
  breadcrumbs={breadcrumbs}
>
  <CountryGrid title="Nach Land durchsuchen" description={description} countries={countries} lang="de" headingLevel="h1" />
</BaseLayout>
