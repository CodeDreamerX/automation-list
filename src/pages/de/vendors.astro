---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import VendorList from "../../components/vendors/VendorList.astro";
import { supabase } from "../../lib/supabaseClient";

// Fetch total active vendor count for meta tags
const { count: totalVendors } = await supabase
  .from('vendors')
  .select('*', { count: 'exact', head: true })
  .neq('plan', 'deactivated');

const metaTitle = totalVendors
  ? `${totalVendors} Automatisierungsanbieter weltweit | Automation List`
  : `Automatisierungsanbieter weltweit | Automation List`;
const metaDescription = totalVendors
  ? `${totalVendors} geprüfte Industrieautomatisierungs-Anbieter weltweit — Systemintegratoren, Maschinenbauer, MES-Spezialisten und mehr. Nach Land, Kategorie, Technologie und Branche filtern.`
  : `Geprüfte Industrieautomatisierungs-Anbieter weltweit — Systemintegratoren, Maschinenbauer, MES-Spezialisten und mehr. Nach Land, Kategorie, Technologie und Branche filtern.`;

const introText =
  "Automation List ist ein herstellerunabhängiges Verzeichnis geprüfter Industrieautomatisierungsunternehmen weltweit. Systemintegratoren, Maschinenbauer, MES-Spezialisten, Robotik-Integratoren und weitere Spezialisten sind filterbar nach Land, Kategorie, Technologie und Branche. Ob Automatisierungspartner für ein Greenfield-Projekt oder Spezialist für eine spezifische Anwendung: Dieses Verzeichnis deckt die gesamte globale Industrieautomatisierung ab.";

// Build breadcrumbs
const breadcrumbs = [
  { label: "Startseite", href: "/de/" },
  { label: "Anbieter", href: "/de/vendors" },
];
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  lang="de"
  breadcrumbs={breadcrumbs}
>
  <VendorList lang="de" pageTitle="Industrieautomatisierungs-Anbieter – Globales Verzeichnis" description={introText} />
</BaseLayout>
