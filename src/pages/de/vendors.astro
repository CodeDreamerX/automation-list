---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import VendorList from "../../components/vendors/VendorList.astro";
import { supabase } from "../../lib/supabaseClient";

// Fetch total active vendor count for meta tags
const { count: totalVendors } = await supabase
  .from('vendors')
  .select('*', { count: 'exact', head: true })
  .neq('plan', 'deactivated');

const metaTitle = totalVendors
  ? `${totalVendors} Industrieautomatisierungs-Anbieter – Europäisches Verzeichnis | Automation List`
  : `Industrieautomatisierungs-Anbieter – Europäisches Verzeichnis | Automation List`;
const metaDescription = totalVendors
  ? `${totalVendors} geprüfte Industrieautomatisierungs-Anbieter aus Europa — Systemintegratoren, Maschinenbauer, MES-Spezialisten und mehr. Nach Land, Kategorie, Technologie und Branche filtern.`
  : `Geprüfte Industrieautomatisierungs-Anbieter aus Europa — Systemintegratoren, Maschinenbauer, MES-Spezialisten und mehr. Nach Land, Kategorie, Technologie und Branche filtern.`;

const introText = "Automation List ist ein herstellerunabhängiges Verzeichnis geprüfter Industrieautomatisierungsunternehmen aus Europa. Systemintegratoren, Maschinenbauer, MES-Spezialisten, Robotik-Integratoren und mehr — filterbar nach Land, Kategorie, Technologie und Branche. Ob Automatisierungspartner für ein Greenfield-Projekt oder Spezialist für eine spezifische Anwendung — dieses Verzeichnis deckt die gesamte europäische Industrieautomatisierung ab.";

// Build breadcrumbs
const breadcrumbs = [
  { label: "Startseite", href: "/de/" },
  { label: "Anbieter", href: "/de/vendors" },
];
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  lang="de"
  breadcrumbs={breadcrumbs}
>
  <VendorList lang="de" pageTitle="Industrieautomatisierungs-Anbieter – Europäisches Verzeichnis" description={introText} />
</BaseLayout>
