---
// Server-Side Rendering (SSR) - This page is rendered on-demand
// See STATIC_GENERATION_STRATEGY.md for details

export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import VendorCard from "../../../components/VendorCard.astro";
import Pagination from "../../../components/Pagination.astro";
import { supabase } from "../../../lib/supabaseClient";
import { getCached, setCached } from "../../../lib/cache";
import { linkifyText } from "../../../lib/linkify";
import { buildPageKeywordMap } from "../../../lib/keyword-map";
import { summarizeSupabaseError } from "../../../lib/supabaseError";
import LucideIcon from "../../../components/LucideIcon.astro";
import CollapsibleIntro from "../../../components/CollapsibleIntro.astro";
import VendorFilter from "../../../components/VendorFilter.astro";
import { normalizeVendors } from "../../../lib/vendors/vendorUtils";
import { getCountryNameMap, slugifyCountry, normalizeCountryName } from "../../../lib/countryUtils";
import { applyMetaDescriptionCountPlaceholder } from "../../../utils/seo";

// Get technology slug from URL param
const techSlug = Astro.params.tech || '';

// If no tech slug, redirect to vendors page
if (!techSlug) {
  return Astro.redirect('/de/vendors');
}

// Fetch technology from database
const { data: technology, error: techError } = await supabase
  .from('technologies')
  .select('id, slug, name_en, name_de, description_en, description_de, meta_description_en, meta_description_de, headline_en, headline_de, meta_title_en, meta_title_de, icon_name, faq_en, faq_de')
  .eq('slug', techSlug)
  .eq('is_active', true)
  .maybeSingle();

if (techError) {
  console.error('Error fetching technology:', techError);
}

// If technology not found, return 404
if (!technology) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const techName = technology.name_de || technology.name_en || techSlug;
const techDescription = technology.description_de || technology.description_en || '';
const countryNameMap = await getCountryNameMap(supabase, getCached, setCached);

// Split description into paragraphs (split on blank lines)
const techDescriptionText = technology.description_de || technology.description_en || '';
const techDescriptionParagraphs = techDescriptionText ? techDescriptionText.split(/\n\s*\n/).filter((p: string) => p.trim()) : [];

// Get pagination params
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));
const pageSize = 102;

// Build cache key
const cacheKey = `vendors:technology:de:${techSlug}:${pageSize}:${page}:v2`;

// Try to get cached result
interface CachedTechnologyResult {
  vendors: any[];
  totalVendors: number | null;
}

let cachedResult = getCached<CachedTechnologyResult>(cacheKey);
let vendors: any[] = [];
let totalVendors: number | null = null;

if (cachedResult) {
  vendors = cachedResult.vendors || [];
  totalVendors = cachedResult.totalVendors;
} else {
  // Get vendor IDs that have this technology via vendor_technologies
  let techVendorIds: string[] = [];
  const { data: techLinks } = await supabase
    .from('vendor_technologies')
    .select('vendor_id')
    .eq('technology_id', technology.id);

  if (techLinks) {
    techVendorIds = techLinks.map(link => link.vendor_id);
  }
  
  // Build query function
  function buildTechnologyQuery() {
    let query = supabase
      .from('vendors')
      .select(`
        *,
        vendor_categories (
          is_primary,
          categories:categories (
            id,
            slug,
            name_en,
            name_de
          )
        ),
        vendor_countries (
          countries:countries (
            id,
            slug,
            name_en,
            name_de,
            flag_emoji
          )
        ),
        vendor_industries (
          industries:industries (
            id,
            slug,
            name_en,
            name_de
          )
        )
      `, { count: 'exact' })
      .neq('plan', 'deactivated');
    
    if (techVendorIds.length === 0) {
      // No vendors match this technology, return empty result
      query = query.eq('id', '00000000-0000-0000-0000-000000000000');
    } else {
      query = query.in('id', techVendorIds);
    }
    
    // Order by profile completeness score first (higher = more complete), then alphabetically by name
    return query
      .order('profile_score', { ascending: false, nullsFirst: false })
      .order('name', { ascending: true });
  }

  // Get total count - use the same vendor IDs from technology filter
  let countQuery = supabase
    .from('vendors')
    .select('*', { count: 'exact', head: true })
    .neq('plan', 'deactivated');
  
  if (techVendorIds.length === 0) {
    countQuery = countQuery.eq('id', '00000000-0000-0000-0000-000000000000');
  } else {
    countQuery = countQuery.in('id', techVendorIds);
  }
  
  const { count } = await countQuery;
  totalVendors = count;

  // Build paginated query
  const start = (page - 1) * pageSize;
  const end = page * pageSize - 1;
  const paginatedQuery = buildTechnologyQuery().range(start, end);

  // Execute paginated query
  const { data, error } = await paginatedQuery;

  if (error) {
    console.error('Error fetching vendors:', summarizeSupabaseError(error));
    vendors = [];
  } else {
    vendors = data || [];
  }

  // Cache the result
  if (totalVendors !== null) {
    setCached(cacheKey, { vendors, totalVendors }, 300);
  }
}

// Normalize category data shape
const normalizedVendors = normalizeVendors(vendors || [], {
  includeCategories: true,
  includeIndustries: true,
  includeCountries: true,
});

const totalPages = Math.ceil((totalVendors || 0) / pageSize);

// Build filterData for VendorFilter
const filterCountryMap = new Map<string, string>();
const filterCategoryMap = new Map<string, string>();
const filterIndustryMap = new Map<string, string>();
for (const v of normalizedVendors) {
  if (v.country) {
    const slug = slugifyCountry(v.country);
    if (slug && !filterCountryMap.has(slug)) {
      const entry = countryNameMap[normalizeCountryName(v.country)];
      filterCountryMap.set(slug, entry?.name_de || entry?.name_en || v.country);
    }
  }
  v.vendor_categories?.forEach((vc: any) => {
    if (vc.categories?.slug) filterCategoryMap.set(vc.categories.slug, vc.categories.name_de || vc.categories.name_en || vc.categories.slug);
  });
  v.vendor_industries?.forEach((vi: any) => {
    if (vi.industries?.slug) filterIndustryMap.set(vi.industries.slug, vi.industries.name_de || vi.industries.name_en || vi.industries.slug);
  });
}
const filterData = {
  country:  [...filterCountryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
  category: [...filterCategoryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
  industry: [...filterIndustryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
};

// FAQ
const rawFaqData = technology.faq_de;
if (!Array.isArray(rawFaqData) || rawFaqData.length === 0) {
  console.error(`[FAQ JSON-LD] Missing or empty faq_de for technology slug: ${techSlug}`);
}
const faqItems = ((rawFaqData ?? []) as any[]).filter(
  (item: any) => item?.question?.trim() && item?.answer?.trim()
);
const hasFaq = faqItems.length > 0;

const keywordMap = buildPageKeywordMap('de', `/de/technology/${techSlug}`);
const seenKeywords = new Set<string>();
const linkedParagraphs = techDescriptionParagraphs.map((p: string) =>
  linkifyText(p.trim(), keywordMap, { maxLinks: 5, firstMatchOnly: true, seenKeywords, minWordGap: 10 })
);
const linkedFaqItems = faqItems.map((item: any) => ({
  ...item,
  linkedAnswer: linkifyText(item.answer, keywordMap, { maxLinks: 1, firstMatchOnly: true, seenKeywords, minWordGap: 10 }),
}));

// SEO metadata
const vendorCount = totalVendors || 0;
const metaTitle = technology.meta_title_de?.trim() || technology.meta_title_en?.trim()
  || (vendorCount >= 8
    ? `${vendorCount} ${techName} Anbieter weltweit | Automation List`
    : `${techName} Anbieter weltweit | Automation List`);
const metaDescriptionRaw =
  technology.meta_description_de?.trim() ||
  technology.meta_description_en?.trim() ||
  (techDescription && techDescription.trim()) ||
  `Finden Sie die besten Industrieautomatisierungsunternehmen, Systemintegratoren und SCADA/PLC-Experten, die sich auf ${techName} spezialisiert haben. Durchsuchen Sie verifizierte Automatisierungsanbieter weltweit.`;
const metaDescription = applyMetaDescriptionCountPlaceholder(metaDescriptionRaw, vendorCount);
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const defaultOgImage = `${siteOrigin}/og/default.png`;
const fullUrl = `${siteOrigin}/de/technology/${techSlug}`;

// Build breadcrumbs
const breadcrumbs = [
  { label: "Startseite", href: "/de/" },
  { label: "Technologien", href: "/de/technologies" },
  { label: techName, href: `/de/technology/${techSlug}` },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Startseite", item: `${siteOrigin}/de/` },
    { "@type": "ListItem", position: 2, name: "Technologien", item: `${siteOrigin}/de/technologies` },
    { "@type": "ListItem", position: 3, name: techName, item: fullUrl },
  ],
};

---

<BaseLayout 
  title={metaTitle}
  description={metaDescription}
  canonical={fullUrl}
  ogImage={defaultOgImage}
  breadcrumbs={breadcrumbs}
  lang="de"
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `Unternehmen für Industrieautomatisierung mit ${techName}`,
    "itemListElement": normalizedVendors.map((v, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Organization",
        "position": index + 1,
        "name": v.name,
        "url": `${siteOrigin}/de/vendor/${v.slug}`,
        "logo": v.logo_url,
        "image": v.logo_url,
        "address": v.country
      }
    }))
  }, null, 2)} />
  {hasFaq && (
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item: any) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer }
      }))
    })} />
  )}
  <div class="container-px mx-auto max-w-7xl px-4 py-10">
    <!-- Technology Header -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        {technology.icon_name && (
          <div class="text-gray-700">
            <LucideIcon name={technology.icon_name} size={56} />
          </div>
        )}
        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2">
            {technology.headline_de || technology.headline_en || `${techName} Anbieter weltweit`}
          </h1>
          {linkedParagraphs.length > 0 && (
            <CollapsibleIntro locale="de">
              {linkedParagraphs.map((html: string) => (
                <p class="mb-4 text-gray-700 leading-relaxed" set:html={html}></p>
              ))}
            </CollapsibleIntro>
          )}
        </div>
      </div>
    </div>

    {normalizedVendors.length > 0 && (
      <VendorFilter filters={['country', 'category', 'industry']} lang="de" filterData={filterData} totalVendors={totalVendors || 0} />
    )}

    <!-- Vendor Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {normalizedVendors.length > 0 ? (
        normalizedVendors.map(vendor => (
          <VendorCard
            vendor={vendor}
            hrefPrefix="/de/vendor"
            lang="de"
            countryNameMap={countryNameMap}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-gray-600">
            Noch keine Anbieter für diese Technologie vorhanden.
          </p>
        </div>
      )}
    </div>

    <!-- Pagination -->
    <Pagination
      currentPage={page}
      totalPages={totalPages}
      baseUrl={Astro.url}
      lang="de"
    />
  </div>

  {hasFaq && (
    <div class="container-px mx-auto max-w-7xl px-4 py-10 border-t border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-6">
        {linkedFaqItems.map((item: any) => (
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.question}</h3>
            <p class="text-gray-700 leading-relaxed" set:html={item.linkedAnswer}></p>
          </div>
        ))}
      </div>
    </div>
  )}
</BaseLayout>

