---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabaseClient";
import { getCached, setCached } from "../../lib/cache";
import { isFeatured } from "../../lib/isFeatured";
import PageHero from "../../components/PageHero.astro";
import WhyThisDirectory from "../../components/WhyThisDirectory.astro";
import SearchForm from "../../components/SearchForm.astro";
import CategoryGrid from "../../components/CategoryGrid.astro";
import IndustryGrid from "../../components/IndustryGrid.astro";
import CountryGrid from "../../components/CountryGrid.astro";
import FeaturedVendors from "../../components/FeaturedVendors.astro";
import ExploreCTA from "../../components/ExploreCTA.astro";
import RecentlyAdded from "../../components/RecentlyAdded.astro";
import VendorConversionBand from "../../components/VendorConversionBand.astro";
import { getCountryNameMap } from "../../lib/countryUtils";
import { getIndustries } from "../../lib/getIndustries";
import { normalizeVendors } from "../../lib/vendors/vendorUtils";
import type { VendorWithRelations } from "../../types/vendor";
import type { Industry } from "../../types/industry";
import { formatTechnologies as formatTechnologiesShared, truncateDescription } from "../../lib/vendors/vendorFormatters";

// --- Featured vendors (300s) ---
let featuredVendors = getCached<VendorWithRelations[]>('home:featured-vendors');
if (!featuredVendors) {
  const now = new Date().toISOString();

  const { data: proVendors } = await supabase
    .from("vendors")
    .select(`
      *,
      vendor_categories (
        is_primary,
        categories:categories (
          name_en,
          name_de
        )
      ),
      vendor_countries (
        countries:countries (
          name_en,
          name_de
        )
      ),
      vendor_technologies (
        technologies:technologies (
          name_en,
          name_de
        )
      )
    `)
    .eq('plan', 'pro')
    .order('priority', { ascending: true, nullsFirst: false })
    .limit(6);

  const { data: featuredVendorsData } = await supabase
    .from("vendors")
    .select(`
      *,
      vendor_categories (
        is_primary,
        categories:categories (
          name_en,
          name_de
        )
      ),
      vendor_countries (
        countries:countries (
          name_en,
          name_de
        )
      ),
      vendor_technologies (
        technologies:technologies (
          name_en,
          name_de
        )
      )
    `)
    .eq('featured', true)
    .gt('featured_until', now)
    .neq('plan', 'deactivated')
    .order('priority', { ascending: true, nullsFirst: false })
    .limit(6);

  const vendorMap = new Map();
  [...(proVendors || []), ...(featuredVendorsData || [])].forEach(v => {
    if (!vendorMap.has(v.id)) vendorMap.set(v.id, v);
  });
  const combined = normalizeVendors(Array.from(vendorMap.values()));
  combined.sort((a, b) => (a.priority || 999) - (b.priority || 999));
  featuredVendors = combined.slice(0, 6);
  setCached('home:featured-vendors', featuredVendors, 300);
}

// --- Fallback vendors (300s) ---
if (featuredVendors.length === 0) {
  let fallback = getCached<VendorWithRelations[]>('home:fallback-vendors');
  if (!fallback) {
    const { data: fallbackData } = await supabase
      .from("vendors")
      .select(`
        *,
        vendor_categories (
          is_primary,
          categories:categories (
            name_en,
            name_de
          )
        ),
        vendor_countries (
          countries:countries (
            name_en,
            name_de
          )
        ),
        vendor_technologies (
          technologies:technologies (
            name_en,
            name_de
          )
        )
      `)
      .neq('plan', 'deactivated')
      .limit(6);
    const normalizedFallback = normalizeVendors(fallbackData || []);
    fallback = [...normalizedFallback].sort(() => Math.random() - 0.5).slice(0, 6);
    setCached('home:fallback-vendors', fallback, 300);
  }
  featuredVendors = fallback;
}

const countryNameMap = await getCountryNameMap(supabase, getCached, setCached);

// Wrapper function to match existing call signature (German page uses lang="de")
function formatTechnologies(vendor: VendorWithRelations): string {
  return formatTechnologiesShared(vendor, "de");
}

// --- Categories (3600s) ---
let dbCategories = getCached<any[]>('home:categories');
if (!dbCategories) {
  const { data } = await supabase
    .from("categories")
    .select("id, slug, name_en, name_de, description_en, description_de, card_description_en, card_description_de, icon_name")
    .eq("is_active", true)
    .order("order_index", { ascending: true });
  dbCategories = data || [];
  setCached('home:categories', dbCategories, 3600);
}

// --- Category counts (300s) ---
let categoryVendorCounts = getCached<any[]>('home:category-counts');
if (!categoryVendorCounts) {
  const { data } = await supabase
    .from("category_vendor_counts")
    .select("category_id, vendor_count");
  categoryVendorCounts = data || [];
  setCached('home:category-counts', categoryVendorCounts, 300);
}

const categoryCountMap = new Map<string, number>();
categoryVendorCounts.forEach((item: any) => {
  if (item.category_id) categoryCountMap.set(item.category_id, item.vendor_count || 0);
});

const categories = dbCategories.map(cat => ({
  slug: cat.slug || '',
  icon_name: cat.icon_name || '',
  name_en: cat.name_en || '',
  name_de: cat.name_de || '',
  description_en: cat.description_en || '',
  description_de: cat.description_de || '',
  card_description_en: cat.card_description_en || '',
  card_description_de: cat.card_description_de || '',
  count: cat.id ? (categoryCountMap.get(cat.id) || 0) : 0,
})).filter(cat => cat.slug && (cat.name_en || cat.name_de));

// --- Total vendor count (300s) ---
let totalVendorCount = getCached<number>('home:total-vendor-count');
if (totalVendorCount === null) {
  const { count } = await supabase
    .from("vendors")
    .select("*", { count: "exact", head: true })
    .neq("plan", "deactivated");
  totalVendorCount = count ?? 0;
  setCached('home:total-vendor-count', totalVendorCount, 300);
}

// --- Country count (3600s) ---
let countryCount = getCached<number>('home:countries-count');
if (countryCount === null) {
  const { count } = await supabase
    .from("countries")
    .select("*", { count: "exact", head: true })
    .eq("is_active", true);
  countryCount = count ?? 0;
  setCached('home:countries-count', countryCount, 3600);
}

// --- Industries (3600s, locale-specific) ---
let allIndustries = getCached<Industry[]>('home:industries:de');
if (!allIndustries) {
  allIndustries = await getIndustries({ lang: "de", activeOnly: true });
  setCached('home:industries:de', allIndustries, 3600);
}

// --- Industry counts (300s) ---
let industryVendorCounts = getCached<any[]>('home:industry-counts');
if (!industryVendorCounts) {
  const { data } = await supabase
    .from("industry_vendor_counts")
    .select("industry_id, vendor_count");
  industryVendorCounts = data || [];
  setCached('home:industry-counts', industryVendorCounts, 300);
}

const industryCountMap = new Map<string, number>();
industryVendorCounts.forEach((item: any) => {
  if (item.industry_id) industryCountMap.set(item.industry_id, item.vendor_count || 0);
});

const industries = allIndustries.slice(0, 12).map(industry => ({
  ...industry,
  count: industry.id ? (industryCountMap.get(industry.id) || 0) : 0,
}));

// --- Countries for homepage grid (shared cache with /countries page) ---
let homeCountriesRaw = getCached<any[]>('taxonomy:countries');
if (!homeCountriesRaw) {
  const { data } = await supabase
    .from('countries')
    .select('id, slug, name_en, name_de, card_description_en, card_description_de, flag_emoji')
    .eq('is_active', true)
    .order('order_index', { ascending: true, nullsFirst: false })
    .order('name_en', { ascending: true });
  homeCountriesRaw = data || [];
  setCached('taxonomy:countries', homeCountriesRaw, 3600);
}

let homeCountRows = getCached<any[]>('counts:country');
if (!homeCountRows) {
  const { data } = await supabase
    .from('country_vendor_counts')
    .select('country, vendor_count');
  homeCountRows = data || [];
  setCached('counts:country', homeCountRows, 300);
}

const homeCountMap = new Map<string, number>();
homeCountRows.forEach((row: any) => {
  if (row.country) homeCountMap.set(row.country.toLowerCase(), row.vendor_count || 0);
});

const homeCountries = homeCountriesRaw
  .map((c) => ({
    slug: c.slug,
    name: c.name_de || c.name_en,
    card_description_en: c.card_description_en,
    card_description_de: c.card_description_de,
    flag_emoji: c.flag_emoji,
    vendor_count: homeCountMap.get((c.name_en || '').toLowerCase()) || 0,
  }))
  .filter((c) => (c.vendor_count || 0) > 0)
  .sort((a, b) =>
    (b.vendor_count || 0) !== (a.vendor_count || 0)
      ? (b.vendor_count || 0) - (a.vendor_count || 0)
      : (a.name || '').localeCompare(b.name || '')
  );

// Build WebSite structured data with SearchAction
// Use production domain for schema.org URLs
const productionOrigin = Astro.site?.origin ?? Astro.url.origin;
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": `${productionOrigin}/de/`,
  "name": "Automation List",
  "description": "Herstellerneutrales Verzeichnis für Industrieautomatisierung. Systemintegratoren, OEMs und Automatisierungsanbieter vergleichen.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${productionOrigin}/de/vendors?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const websiteSchemaJson = JSON.stringify(websiteSchema);
const activeCategoryCount = categories.length;
const activeCountryCount = countryCount ?? 0;
const dynamicMetaDescription = `Verifizierte Industrieautomation-Anbieter weltweit finden und vergleichen — Systemintegratoren, MES-Spezialisten, Robotik-Integratoren, Maschinenbauer und mehr. ${activeCategoryCount} Kategorien, ${activeCountryCount} Länder.`;

---

<BaseLayout 
  title="Verzeichnis für Industrieautomation Anbieter | Automation-List"
  description={dynamicMetaDescription}
  canonical="https://www.automation-list.com/de/"
  ogUrl="https://www.automation-list.com/de/"
  ogImage="https://www.automation-list.com/og/default.png"
  lang="de"
>
  <script slot="head" type="application/ld+json" set:html={websiteSchemaJson} />

  <PageHero
    title="Anbieterverzeichnis für Industrieautomatisierung"
    description="Das anbieterneutrale Automatisierungsverzeichnis – von Ingenieuren erstellt, nicht von Agenturen. Finden und vergleichen Sie Systemintegratoren, OEMs und Spezialisten weltweit."
    vendorCount={totalVendorCount}
    vendorCountLabel="gelistete geprüfte Automatisierungsanbieter"
    countryCount={countryCount}
    countriesHref="/de/countries"
    countryConnectorText="in"
    countryLabelText="Ländern"
    primaryButtonText="Verzeichnis durchsuchen →"
    primaryButtonHref="/de/vendors"
    secondaryLabelText={`${totalVendorCount} Anbieter gelistet — fehlt Ihrer?`}
    secondaryButtonText="Kostenloses Profil eintragen →"
    secondaryButtonHref="/de/submit-listing"
    secondaryMicroCopy="Keine Kreditkarte erforderlich"
  />

  <SearchForm
    title="Verzeichnis durchsuchen"
    action="/de/vendors"
    placeholder="Name, Fähigkeit oder Stichwort suchen"
    buttonText="Suchen"
  />

  <div class="container-px mx-auto max-w-7xl px-4 py-4 flex flex-wrap justify-center gap-3">
    <a href="#browse-categories" class="btn-secondary">Nach Kategorie</a>
    <a href="#browse-industries" class="btn-secondary">Nach Branche</a>
    <a href="#browse-countries" class="btn-secondary">Nach Land</a>
  </div>

  <WhyThisDirectory
    title="Warum dieses Verzeichnis?"
    description="Automation-List ist ein anbieterneutrales Verzeichnis, das von Automatisierungsingenieuren erstellt wurde. Keine gesponserten Rankings, keine Agenturen, die Ergebnisse manipulieren — nur saubere, strukturierte Daten."
    benefits={[
      "Anbieterneutral und unvoreingenommen",
      "Erstellt von Automatisierungsfachleuten",
      "Klare Kategorien und Technologiezuordnung",
      "Globale Abdeckung",
      "Ständige Weiterentwicklung",
    ]}
    forEngineersTitle="Für Ingenieure"
    forVendorsTitle="Für Anbieter"
    forVendorsBenefits={[
      "Kostenlose Dauerlisting — keine Provision, kein Haken",
      "Das Verzeichnis wird bei Google gefunden und von KI-Suchtools wie Bing Copilot referenziert",
      "Eintrag in 5 Minuten — wir prüfen und veröffentlichen manuell",
    ]}
  />

  <FeaturedVendors
    title="Ausgewählte Anbieter"
    vendors={featuredVendors}
    viewAllHref="/de/vendors"
    viewAllText="Alle Anbieter anzeigen →"
    vendorHrefPrefix="/de/vendor"
    vendorLinkText="Profil anzeigen →"
    lang="de"
    countryNameMap={countryNameMap}
    formatTechnologies={formatTechnologies}
    truncateDescription={truncateDescription}
    isFeatured={isFeatured}
  />

  <SearchForm
    title="Verzeichnis durchsuchen"
    action="/de/vendors"
    placeholder="Name, Fähigkeit oder Stichwort suchen"
    buttonText="Suchen"
  />

  <CategoryGrid
    title="Nach Kategorie durchsuchen"
    categories={categories}
    lang="de"
    id="browse-categories"
  />

  <IndustryGrid
    title="Nach Branche"
    industries={industries}
    lang="de"
    id="browse-industries"
  />

  <CountryGrid
    title="Nach Land durchsuchen"
    countries={homeCountries}
    lang="de"
    id="browse-countries"
  />

  <RecentlyAdded lang="de" />

  <ExploreCTA
    title="Bereit, Automatisierungsanbieter zu erkunden?"
    description="Finden Sie vertrauenswürdige Integratoren und Automatisierungspartner weltweit."
    primaryButtonText="Verzeichnis durchsuchen →"
    primaryButtonHref="/de/vendors"
  />
</BaseLayout>

