---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import VendorCard from "../../../components/VendorCard.astro";
import Pagination from "../../../components/Pagination.astro";
import CollapsibleIntro from "../../../components/CollapsibleIntro.astro";
import VendorFilter from "../../../components/VendorFilter.astro";
import { supabase } from "../../../lib/supabaseClient";
import { getCached, setCached } from "../../../lib/cache";
import { linkifyText } from "../../../lib/linkify";
import { buildPageKeywordMap } from "../../../lib/keyword-map";
import { normalizeVendors } from "../../../lib/vendors/vendorUtils";
import { getCountryNameMap, parseCountryParam, slugifyCountry } from "../../../lib/countryUtils";
import type { FaqItem } from "../../../types/industry";

const countryParam = Astro.params.country || '';
const normalizedCountry = parseCountryParam(countryParam);

if (!normalizedCountry) return Astro.redirect('/de/vendors');

const countrySlug = slugifyCountry(normalizedCountry);
if (!countrySlug) return Astro.redirect('/de/vendors');
const countryNameMap = await getCountryNameMap(supabase, getCached, setCached);

if (countryParam !== countrySlug) {
  return Astro.redirect(`/de/country/${countrySlug}${Astro.url.search}`);
}

// Try to find managed country record in DB for rich content
const { data: countryRecord } = await supabase
  .from('countries')
  .select('id, slug, name_en, name_de, description_en, description_de, flag_emoji, faq_en, faq_de, headline_en, headline_de, meta_title_en, meta_title_de, meta_description_en, meta_description_de')
  .eq('slug', countrySlug)
  .eq('is_active', true)
  .maybeSingle();

const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));
const pageSize = 102;

function capitalizeCountry(country: string): string {
  return country.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');
}

const cacheKey = `vendors:country:de:${countryParam}:${pageSize}:${page}:v2`;

interface CachedCountryResult {
  vendors: any[];
  totalVendors: number | null;
}

let cachedResult = getCached<CachedCountryResult>(cacheKey);
let vendors: any[] = [];
let totalVendors: number | null = null;

if (cachedResult) {
  vendors = cachedResult.vendors || [];
  totalVendors = cachedResult.totalVendors;
} else {
  function buildCountryQuery() {
    return supabase
      .from('vendors')
      .select(`
        *,
        vendor_categories (
          is_primary,
          categories:categories (
            id,
            slug,
            name_en,
            name_de
          )
        ),
        vendor_countries (
          countries:countries (
            id,
            slug,
            name_en,
            name_de,
            flag_emoji
          )
        ),
        vendor_industries (
          industries:industries (
            id,
            slug,
            name_en,
            name_de
          )
        ),
        vendor_technologies (
          technologies:technologies (
            id,
            slug,
            name_en,
            name_de
          )
        )
      `)
      .ilike('country', normalizedCountry)
      .neq('plan', 'deactivated')
      .order('profile_score', { ascending: false, nullsFirst: false })
      .order('name', { ascending: true });
  }

  const { data: countryCount } = await supabase
    .from('country_vendor_counts')
    .select('vendor_count')
    .ilike('country', normalizedCountry)
    .single();
  totalVendors = countryCount?.vendor_count || null;

  const start = (page - 1) * pageSize;
  const end = page * pageSize - 1;
  const { data, error } = await buildCountryQuery().range(start, end);

  if (error) {
    console.error('Error fetching vendors:', error);
    vendors = [];
  } else {
    vendors = data || [];
  }

  if (totalVendors !== null) {
    setCached(cacheKey, { vendors, totalVendors }, 300);
  }
}

const normalizedVendors = normalizeVendors(vendors || [], {
  includeCategories: true,
  includeIndustries: true,
  includeTechnologies: true,
  includeCountries: true,
});
const totalPages = Math.ceil((totalVendors || 0) / pageSize);

// Build filterData for VendorFilter
const filterCategoryMap = new Map<string, string>();
const filterIndustryMap = new Map<string, string>();
const filterTechnologyMap = new Map<string, string>();
for (const v of normalizedVendors) {
  v.vendor_categories?.forEach((vc: any) => {
    if (vc.categories?.slug) filterCategoryMap.set(vc.categories.slug, vc.categories.name_de || vc.categories.name_en || vc.categories.slug);
  });
  v.vendor_industries?.forEach((vi: any) => {
    if (vi.industries?.slug) filterIndustryMap.set(vi.industries.slug, vi.industries.name_de || vi.industries.name_en || vi.industries.slug);
  });
  v.vendor_technologies?.forEach((vt: any) => {
    if (vt.technologies?.slug) filterTechnologyMap.set(vt.technologies.slug, vt.technologies.name_de || vt.technologies.name_en || vt.technologies.slug);
  });
}
const filterData = {
  category:   [...filterCategoryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
  industry:   [...filterIndustryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
  technology: [...filterTechnologyMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
};

// Display name: prefer DE from DB, then EN, then vendor field, then capitalize
let displayCountry = countryRecord?.name_de
  || countryRecord?.name_en
  || (normalizedVendors.length > 0 ? normalizedVendors[0].country : null)
  || capitalizeCountry(normalizedCountry);

const flagEmoji = countryRecord?.flag_emoji || '';
const pageHeading = countryRecord?.headline_de || countryRecord?.headline_en || `Industrieautomation ${displayCountry}`;

// Description paragraphs (prefer DE, fallback EN)
const descriptionText = countryRecord?.description_de || countryRecord?.description_en || '';
const descriptionParagraphs = descriptionText ? descriptionText.split(/\n\s*\n/).filter((p: string) => p.trim()) : [];

// FAQ (prefer DE, fallback EN)
const faqItems = ((countryRecord?.faq_de ?? countryRecord?.faq_en ?? []) as FaqItem[]).filter(
  (item) => item?.question?.trim() && item?.answer?.trim()
);
const hasFaq = faqItems.length > 0;

const keywordMap = buildPageKeywordMap('de');
const seenKeywords = new Set<string>();
const linkedParagraphs = descriptionParagraphs.map((p: string) =>
  linkifyText(p.trim(), keywordMap, { maxLinks: 5, firstMatchOnly: true, seenKeywords, minWordGap: 10 })
);
const linkedFaqItems = faqItems.map((item) => ({
  ...item,
  linkedAnswer: linkifyText(item.answer, keywordMap, { maxLinks: 1, firstMatchOnly: true, seenKeywords, minWordGap: 10 }),
}));

// SEO
const countryAdjectives: Record<string, string> = {
  'Switzerland': 'Schweizer',
  'Germany': 'deutsche',
  'United Kingdom': 'britische',
  'France': 'französische',
  'Netherlands': 'niederländische',
  'Belgium': 'belgische',
  'Sweden': 'schwedische',
  'Poland': 'polnische',
  'Denmark': 'dänische',
  'Austria': 'österreichische',
  'Italy': 'italienische',
  'Spain': 'spanische',
  'Finland': 'finnische',
  'Norway': 'norwegische',
  'Czech Republic': 'tschechische',
};
const countryAdj = countryAdjectives[displayCountry] ?? displayCountry;

const germanLocationMap: Record<string, string> = {
  'Schweiz': 'der Schweiz',
  'Switzerland': 'der Schweiz',
  'Türkei': 'der Türkei',
  'Turkey': 'der Türkei',
  'Slowakei': 'der Slowakei',
  'Slovakia': 'der Slowakei',
  'Ukraine': 'der Ukraine',
  'Niederlande': 'den Niederlanden',
  'Netherlands': 'den Niederlanden',
  'Tschechische Republik': 'der Tschechischen Republik',
  'Czech Republic': 'der Tschechischen Republik',
  'Vereinigtes Königreich': 'dem Vereinigten Königreich',
  'United Kingdom': 'dem Vereinigten Königreich',
  'Vereinigte Staaten': 'den Vereinigten Staaten',
  'United States': 'den Vereinigten Staaten',
};
const germanLocation = germanLocationMap[displayCountry] ?? displayCountry;
const seoTitle = countryRecord?.meta_title_de?.trim() || countryRecord?.meta_title_en?.trim()
  || (totalVendors
    ? `${totalVendors} Automatisierungsanbieter in ${germanLocation} | Automation List`
    : `Automatisierungsanbieter in ${germanLocation} | Automation List`);
const seoDescription = countryRecord?.meta_description_de?.trim() || countryRecord?.meta_description_en?.trim()
  || (totalVendors
    ? `${totalVendors} geprüfte ${countryAdj} Automatisierungsanbieter – Systemintegratoren, MES-Spezialisten, Maschinenbauer und mehr. Nach Kategorie, Technologie und Branche filtern.`
    : `Geprüfte ${countryAdj} Automatisierungsanbieter – Systemintegratoren, MES-Spezialisten, Maschinenbauer und mehr. Nach Kategorie, Technologie und Branche filtern.`);
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const defaultOg = `${siteOrigin}/og/default.png`;
const currentUrl = `${siteOrigin}/de/country/${countrySlug}`;

const breadcrumbs = [
  { label: "Startseite", href: "/de/" },
  { label: "Länder", href: "/de/countries" },
  { label: displayCountry, href: `/de/country/${countrySlug}` },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Startseite", item: `${siteOrigin}/de/` },
    { "@type": "ListItem", position: 2, name: "Länder", item: `${siteOrigin}/de/countries` },
    { "@type": "ListItem", position: 3, name: displayCountry, item: currentUrl },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Industrieautomatisierungsunternehmen in ${displayCountry}`,
  "itemListElement": normalizedVendors.map((v, index) => ({
    "@type": "Organization",
    "position": index + 1,
    "name": v.name,
    "url": `${siteOrigin}/de/vendor/${v.slug}`,
    "logo": v.logo_url,
    "image": v.logo_url,
    "address": v.country,
  })),
};

const faqSchema = hasFaq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
} : null;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical={currentUrl}
  ogImage={defaultOg}
  lang="de"
  breadcrumbs={breadcrumbs}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  {faqSchema && (
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <div class="container-px mx-auto max-w-7xl px-4 py-10">
    <div class="mb-4 flex items-center gap-2">
      {flagEmoji && (
        <img
          src={`https://flagcdn.com/32x24/${flagEmoji.toLowerCase()}.png`}
          width="32"
          height="24"
          alt=""
          class="inline-block align-middle"
        />
      )}
      <h1 class="text-3xl font-bold text-gray-900">{pageHeading}</h1>
    </div>

    {linkedParagraphs.length > 0 && (
      <div class="mb-8">
        <CollapsibleIntro locale="de">
          <div class="prose prose-gray max-w-none text-gray-700">
            {linkedParagraphs.map((html: string) => (
              <p set:html={html}></p>
            ))}
          </div>
        </CollapsibleIntro>
        <a
          href="/de/vendors"
          class="mt-2 inline-flex items-center gap-1 rounded-md border border-brand-200/80 bg-brand-50 px-3.5 py-2 text-sm font-bold text-brand-800 shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-100 hover:text-brand-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
        >
          Alle Anbieter durchsuchen →
        </a>
      </div>
    )}

    {normalizedVendors.length > 0 && (
      <VendorFilter filters={['category', 'industry', 'technology']} lang="de" filterData={filterData} totalVendors={totalVendors || 0} />
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {normalizedVendors.length > 0 ? (
        normalizedVendors.map(vendor => (
          <VendorCard vendor={vendor} hrefPrefix="/de/vendor" lang="de" countryNameMap={countryNameMap} />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-gray-600">Keine Anbieter in diesem Land gefunden.</p>
        </div>
      )}
    </div>

    <Pagination currentPage={page} totalPages={totalPages} baseUrl={Astro.url} lang="de" />

    {hasFaq && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Häufig gestellte Fragen</h2>
        <div class="space-y-6">
          {linkedFaqItems.map((item) => (
            <div class="border-b border-gray-200 pb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.question}</h3>
              <p class="text-gray-700" set:html={item.linkedAnswer}></p>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
