---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import slugRef from "../../data/slug-reference.json";

type SlugItem = { slug: string; name: string };
const { categories, technologies, industries, certifications } = slugRef as {
  categories: SlugItem[];
  technologies: SlugItem[];
  industries: SlugItem[];
  certifications: SlugItem[];
};

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';

const LANGUAGES = [
  'Englisch', 'Deutsch', 'Französisch', 'Italienisch', 'Spanisch',
  'Niederländisch', 'Polnisch', 'Tschechisch', 'Rumänisch', 'Ungarisch', 'Portugiesisch',
];
---

<BaseLayout
  title="Unternehmen eintragen | Automation List"
  description="Tragen Sie Ihr Industrieautomatisierungsunternehmen in die Automation List ein. Werden Sie von Ingenieuren und Einkäufern in ganz Europa entdeckt."
  lang="de"
>
  <div class="max-w-2xl mx-auto px-4 py-12 md:py-16">

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Unternehmen eintragen</h1>
      <p class="text-gray-600 text-sm leading-relaxed">
        Tragen Sie Ihr Unternehmen in das Automation List Verzeichnis ein. Füllen Sie die Pflichtfelder aus und fügen Sie optional weitere Details hinzu, um die Prüfung zu beschleunigen.
        Einträge werden innerhalb von 1–2 Werktagen geprüft.
      </p>
    </div>

    <!-- Success state (hidden until form submits) -->
    <div id="success-state" class="hidden bg-green-50 border border-green-200 rounded-xl px-6 py-10 text-center">
      <div class="text-3xl text-green-500 mb-3">✓</div>
      <h2 class="text-lg font-semibold text-green-800 mb-2">Eintrag eingereicht!</h2>
      <p class="text-green-700 text-sm max-w-sm mx-auto">
        Ihr Eintrag wurde eingereicht und wird derzeit geprüft. Wir melden uns innerhalb von 1–2 Werktagen bei Ihnen.
      </p>
    </div>

    <!-- Error banner -->
    <div id="error-banner" class="hidden mb-6 flex items-start gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm" role="alert">
      <span id="error-message"></span>
    </div>

    <!-- ==================== FORM ==================== -->
    <form id="submit-form" novalidate>

      <!-- Honeypot: visually hidden, bots may fill it -->
      <div aria-hidden="true" style="position:absolute;opacity:0;pointer-events:none;overflow:hidden;height:0;width:0;left:-9999px;">
        <label>Leave this empty<input type="text" name="website_url" tabindex="-1" autocomplete="off" /></label>
      </div>

      <!-- ========== SECTION 1: Required ========== -->
      <div class="bg-white border border-gray-200 rounded-xl p-6 space-y-5">
        <h2 class="text-sm font-semibold text-gray-900 border-b border-gray-100 pb-3 uppercase tracking-wide">
          Unternehmensdetails
          <span class="text-xs font-normal text-red-500 ml-1 normal-case tracking-normal">* erforderlich</span>
        </h2>

        <!-- Company Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            Firmenname <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
            placeholder="Acme Automation GmbH"
          />
          <p id="name-error" class="hidden mt-1 text-xs text-red-600">Firmenname ist erforderlich</p>
        </div>

        <!-- Website -->
        <div>
          <label for="website" class="block text-sm font-medium text-gray-700 mb-1">
            Website <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="website"
            name="website"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
            placeholder="https://example.com"
          />
          <p id="website-error" class="hidden mt-1 text-xs text-red-600">Eine gültige Website-URL ist erforderlich</p>
        </div>

        <!-- Contact Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Kontakt-E-Mail <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
            placeholder="hallo@beispiel.de"
          />
          <p id="email-error" class="hidden mt-1 text-xs text-red-600">Eine gültige E-Mail-Adresse ist erforderlich</p>
        </div>

        <!-- Country (searchable single-select) -->
        <div>
          <label for="country-input" class="block text-sm font-medium text-gray-700 mb-1">
            Land <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <input
              type="text"
              id="country-input"
              class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
              placeholder="Länder suchen..."
              autocomplete="off"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false"
              aria-controls="country-dropdown"
            />
            <input type="hidden" id="country-value" name="country" />
            <div
              id="country-dropdown"
              role="listbox"
              class="hidden absolute z-30 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-52 overflow-y-auto text-sm"
            ></div>
          </div>
          <p id="country-error" class="hidden mt-1 text-xs text-red-600">Bitte wählen Sie ein Land aus der Liste</p>
        </div>

        <!-- Categories (checkbox grid) -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Kategorien <span class="text-red-500">*</span>
            <span class="font-normal text-gray-400 ml-1">(alle zutreffenden auswählen)</span>
          </label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
            {categories.map((cat) => (
              <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                <input
                  type="checkbox"
                  name="category_slugs"
                  value={cat.slug}
                  class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0"
                />
                <span>{cat.name}</span>
              </label>
            ))}
          </div>
          <p id="categories-error" class="hidden mt-2 text-xs text-red-600">Bitte wählen Sie mindestens eine Kategorie aus</p>
        </div>

        <!-- Description (English) -->
        <div>
          <label for="description_en" class="block text-sm font-medium text-gray-700 mb-1">
            Beschreibung <span class="text-red-500">*</span>
            <span class="font-normal text-gray-400 ml-1">(Englisch)</span>
          </label>
          <textarea
            id="description_en"
            name="description_en"
            rows="4"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white resize-y"
            placeholder="Describe your company, specialisation, and what makes you stand out..."
          ></textarea>
          <p id="description_en-error" class="hidden mt-1 text-xs text-red-600">Eine englische Beschreibung ist erforderlich</p>
        </div>

        <!-- Description (German) — optional -->
        <div>
          <label for="description_de" class="block text-sm font-medium text-gray-700 mb-1">
            Beschreibung
            <span class="font-normal text-gray-400 ml-1">(Deutsch, optional)</span>
          </label>
          <textarea
            id="description_de"
            name="description_de"
            rows="4"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white resize-y"
            placeholder="Beschreiben Sie Ihr Unternehmen und Ihre Dienstleistungen auf Deutsch..."
          ></textarea>
        </div>

      </div>
      <!-- end Section 1 -->

      <!-- ========== SECTION 2: Optional / Collapsible ========== -->
      <div class="mt-4">
        <button
          type="button"
          id="section2-toggle"
          class="w-full flex items-center justify-between px-4 py-3 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl text-sm font-medium text-gray-700 transition-colors text-left"
        >
          <span id="section2-label">+ Weitere Details hinzufügen — je mehr Sie angeben, desto schneller wird Ihr Eintrag freigeschaltet</span>
          <svg
            id="section2-chevron"
            class="w-4 h-4 text-gray-400 transition-transform duration-200 flex-shrink-0 ml-3"
            viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
          >
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>

        <div id="section2-content" class="hidden mt-3 bg-white border border-gray-200 rounded-xl p-6 space-y-6">

          <!-- City / Region -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="city" class="block text-sm font-medium text-gray-700 mb-1">Stadt</label>
              <input type="text" id="city" name="city" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="München" />
            </div>
            <div>
              <label for="region" class="block text-sm font-medium text-gray-700 mb-1">Region / Bundesland</label>
              <input type="text" id="region" name="region" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="Bayern" />
            </div>
          </div>

          <!-- Phone / LinkedIn -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
              <input type="text" id="phone" name="phone" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="+49 89 ..." />
            </div>
            <div>
              <label for="linkedin_url" class="block text-sm font-medium text-gray-700 mb-1">LinkedIn-URL</label>
              <input type="url" id="linkedin_url" name="linkedin_url" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="https://linkedin.com/company/..." />
            </div>
          </div>

          <!-- Technologies -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Technologien / Plattformen</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {technologies.map((tech) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="technology_slugs" value={tech.slug} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{tech.name}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Industries -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Bediente Branchen</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {industries.map((ind) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="industry_slugs" value={ind.slug} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{ind.name}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Certifications -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Zertifizierungen</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {certifications.map((cert) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="certification_slugs" value={cert.slug} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{cert.name}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Languages -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Servicesprachen</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {LANGUAGES.map((lang) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="languages" value={lang} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{lang}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Countries Served (text) -->
          <div>
            <label for="countries_served" class="block text-sm font-medium text-gray-700 mb-1">Belieferte Länder</label>
            <input
              type="text"
              id="countries_served"
              class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
              placeholder="z.B. DACH-Region, Deutschland, Österreich, Schweiz"
            />
          </div>

          <!-- Year Founded / Employee Count -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="year_founded" class="block text-sm font-medium text-gray-700 mb-1">Gründungsjahr</label>
              <input
                type="number"
                id="year_founded"
                name="year_founded"
                min="1800"
                max="2099"
                class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
                placeholder="2005"
              />
            </div>
            <div>
              <label for="employee_count" class="block text-sm font-medium text-gray-700 mb-1">Unternehmensgröße</label>
              <select
                id="employee_count"
                name="employee_count"
                class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
              >
                <option value="">Auswählen...</option>
                <option value="1-10">1–10 Mitarbeiter</option>
                <option value="11-50">11–50 Mitarbeiter</option>
                <option value="51-200">51–200 Mitarbeiter</option>
                <option value="201-500">201–500 Mitarbeiter</option>
                <option value="500+">500+ Mitarbeiter</option>
              </select>
            </div>
          </div>

          <!-- Taking new projects -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Nehmen Sie derzeit neue Projekte an?</label>
            <div class="flex gap-2 flex-wrap" id="new-projects-toggle">
              <button type="button" data-value="true"  class="toggle-opt px-4 py-1.5 text-sm border border-gray-300 rounded-full text-gray-600 hover:border-gray-500 transition-colors">Ja</button>
              <button type="button" data-value="false" class="toggle-opt px-4 py-1.5 text-sm border border-gray-300 rounded-full text-gray-600 hover:border-gray-500 transition-colors">Nein</button>
              <button type="button" data-value=""      class="toggle-opt px-4 py-1.5 text-sm border border-gray-300 rounded-full text-gray-600 hover:border-gray-500 transition-colors">Keine Angabe</button>
            </div>
            <input type="hidden" id="taking-new-projects" value="" />
          </div>

        </div>
        <!-- end section2-content -->
      </div>
      <!-- end Section 2 -->

      <!-- Cloudflare Turnstile -->
      {turnstileSiteKey && (
        <div class="mt-6">
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
        </div>
      )}

      <!-- Submit -->
      <div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-3">
        <button
          type="submit"
          id="submit-btn"
          class="px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Eintrag einreichen
        </button>
        <p class="text-xs text-gray-400">
          Mit dem Absenden bestätigen Sie, dass diese Angaben korrekt sind. Einträge werden manuell geprüft, bevor sie live gehen.
        </p>
      </div>

    </form>
    <!-- end form -->

  </div>
</BaseLayout>

<script define:vars={{ turnstileSiteKey }}>

// ---- Load Cloudflare Turnstile script dynamically ----
if (turnstileSiteKey && !document.querySelector('script[src*="turnstile"]')) {
  const ts = document.createElement('script');
  ts.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
  ts.async = true;
  ts.defer = true;
  document.head.appendChild(ts);
}

// ---- ISO 3166 country list ----
const ISO_COUNTRIES = [
  "Afghanistan","Albania","Algeria","Andorra","Angola","Argentina","Armenia",
  "Australia","Austria","Azerbaijan","Bahrain","Bangladesh","Belarus","Belgium",
  "Bolivia","Bosnia and Herzegovina","Brazil","Bulgaria","Cambodia","Canada",
  "Chile","China","Colombia","Costa Rica","Croatia","Cyprus","Czech Republic",
  "Denmark","Ecuador","Egypt","Estonia","Ethiopia","Finland","France","Georgia",
  "Germany","Ghana","Greece","Hong Kong","Hungary","India","Indonesia","Iran",
  "Iraq","Ireland","Israel","Italy","Japan","Jordan","Kazakhstan","Kenya",
  "Kuwait","Latvia","Lebanon","Lithuania","Luxembourg","Malaysia","Mexico",
  "Morocco","Netherlands","New Zealand","Nigeria","North Macedonia","Norway",
  "Oman","Pakistan","Peru","Philippines","Poland","Portugal","Qatar","Romania",
  "Russia","Saudi Arabia","Serbia","Singapore","Slovakia","Slovenia",
  "South Africa","South Korea","Spain","Sri Lanka","Sweden","Switzerland",
  "Taiwan","Thailand","Tunisia","Turkey","Ukraine","United Arab Emirates",
  "United Kingdom","United States","Uruguay","Uzbekistan","Venezuela","Vietnam",
  "Zimbabwe"
];

// ================================================================
// Country picker (single-select with custom dropdown)
// ================================================================
const countryInput  = document.getElementById('country-input');
const countryValue  = document.getElementById('country-value');
const countryDropdown = document.getElementById('country-dropdown');

function buildCountryDropdown(query) {
  const q = query.trim().toLowerCase();
  const matches = q ? ISO_COUNTRIES.filter(c => c.toLowerCase().includes(q)) : ISO_COUNTRIES;
  countryDropdown.innerHTML = matches.length
    ? matches.map(c =>
        `<div class="country-opt px-3 py-2 cursor-pointer hover:bg-gray-50 text-gray-800" data-value="${c}">${c}</div>`
      ).join('')
    : `<div class="px-3 py-2 text-gray-400 text-sm">Keine Ergebnisse</div>`;
}

countryInput.addEventListener('focus', () => {
  buildCountryDropdown(countryInput.value);
  countryDropdown.classList.remove('hidden');
  countryInput.setAttribute('aria-expanded', 'true');
});

countryInput.addEventListener('input', () => {
  countryValue.value = '';
  buildCountryDropdown(countryInput.value);
  countryDropdown.classList.remove('hidden');
});

countryDropdown.addEventListener('mousedown', (e) => {
  const opt = e.target.closest('.country-opt');
  if (!opt) return;
  countryInput.value  = opt.dataset.value;
  countryValue.value  = opt.dataset.value;
  countryDropdown.classList.add('hidden');
  countryInput.setAttribute('aria-expanded', 'false');
  clearFieldError('country-input', 'country-error');
});

document.addEventListener('click', (e) => {
  if (!countryInput.contains(e.target) && !countryDropdown.contains(e.target)) {
    countryDropdown.classList.add('hidden');
    countryInput.setAttribute('aria-expanded', 'false');
    if (countryInput.value && !ISO_COUNTRIES.includes(countryInput.value)) {
      countryInput.value = '';
      countryValue.value = '';
    }
  }
});


// ================================================================
// Section 2 toggle
// ================================================================
const s2Toggle  = document.getElementById('section2-toggle');
const s2Content = document.getElementById('section2-content');
const s2Chevron = document.getElementById('section2-chevron');
const s2Label   = document.getElementById('section2-label');

s2Toggle.addEventListener('click', () => {
  const opening = s2Content.classList.contains('hidden');
  s2Content.classList.toggle('hidden', !opening);
  s2Chevron.style.transform = opening ? 'rotate(180deg)' : '';
  s2Label.textContent = opening
    ? '− Details ausblenden'
    : '+ Weitere Details hinzufügen — je mehr Sie angeben, desto schneller wird Ihr Eintrag freigeschaltet';
});

// ================================================================
// Taking new projects toggle
// ================================================================
const toggleOpts  = document.querySelectorAll('.toggle-opt');
const tnpInput    = document.getElementById('taking-new-projects');

toggleOpts.forEach(btn => {
  btn.addEventListener('click', () => {
    toggleOpts.forEach(b => {
      b.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
      b.classList.add('text-gray-600', 'border-gray-300');
    });
    btn.classList.remove('text-gray-600', 'border-gray-300');
    btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
    tnpInput.value = btn.dataset.value;
  });
});

// ================================================================
// Validation helpers
// ================================================================
function markError(inputEl, errorId) {
  if (inputEl) inputEl.classList.add('!border-red-400', 'focus:!ring-red-300');
  document.getElementById(errorId)?.classList.remove('hidden');
}

function clearFieldError(inputId, errorId) {
  const el = typeof inputId === 'string' ? document.getElementById(inputId) : inputId;
  if (el) el.classList.remove('!border-red-400', 'focus:!ring-red-300');
  document.getElementById(errorId)?.classList.add('hidden');
}

function clearAllErrors() {
  document.querySelectorAll('[id$="-error"]').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.sl-input').forEach(el => el.classList.remove('!border-red-400', 'focus:!ring-red-300'));
  document.getElementById('error-banner').classList.add('hidden');
}

function showBanner(msg) {
  const banner = document.getElementById('error-banner');
  document.getElementById('error-message').textContent = msg;
  banner.classList.remove('hidden');
  banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function validateForm() {
  let valid = true;

  const nameEl = document.getElementById('name');
  if (!nameEl.value.trim()) { markError(nameEl, 'name-error'); valid = false; }
  else clearFieldError(nameEl, 'name-error');

  const websiteEl = document.getElementById('website');
  const wsRaw = websiteEl.value.trim();
  const wsNorm = (wsRaw.startsWith('http://') || wsRaw.startsWith('https://'))
    ? wsRaw : 'https://' + wsRaw;
  try {
    if (!wsRaw) throw new Error('empty');
    new URL(wsNorm);
    websiteEl.value = wsNorm;
    clearFieldError(websiteEl, 'website-error');
  } catch {
    markError(websiteEl, 'website-error');
    valid = false;
  }

  const emailEl = document.getElementById('email');
  if (!emailEl.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value)) {
    markError(emailEl, 'email-error'); valid = false;
  } else clearFieldError(emailEl, 'email-error');

  if (!countryValue.value) {
    markError(countryInput, 'country-error'); valid = false;
  } else clearFieldError(countryInput, 'country-error');

  const catChecked = document.querySelectorAll('[name="category_slugs"]:checked');
  const catErrEl = document.getElementById('categories-error');
  if (catChecked.length === 0) { catErrEl.classList.remove('hidden'); valid = false; }
  else catErrEl.classList.add('hidden');

  const descEnEl = document.getElementById('description_en');
  if (!descEnEl.value.trim()) { markError(descEnEl, 'description_en-error'); valid = false; }
  else clearFieldError(descEnEl, 'description_en-error');

  return valid;
}

// ================================================================
// Collect payload
// ================================================================
function collectPayload(isSuspect) {
  const tknEl = document.querySelector('[name="cf-turnstile-response"]');
  const yearVal = document.getElementById('year_founded').value;
  const tnpVal = tnpInput.value;

  return {
    name: document.getElementById('name').value.trim(),
    website: document.getElementById('website').value.trim(),
    email: document.getElementById('email').value.trim(),
    country: countryValue.value,
    category_slugs: [...document.querySelectorAll('[name="category_slugs"]:checked')].map(el => el.value),
    description_en: document.getElementById('description_en').value.trim(),
    description_de: document.getElementById('description_de').value.trim() || null,
    city: document.getElementById('city').value.trim() || null,
    region: document.getElementById('region').value.trim() || null,
    phone: document.getElementById('phone').value.trim() || null,
    linkedin_url: document.getElementById('linkedin_url').value.trim() || null,
    technology_slugs: [...document.querySelectorAll('[name="technology_slugs"]:checked')].map(el => el.value),
    industry_slugs:   [...document.querySelectorAll('[name="industry_slugs"]:checked')].map(el => el.value),
    certification_slugs: [...document.querySelectorAll('[name="certification_slugs"]:checked')].map(el => el.value),
    languages: [...document.querySelectorAll('[name="languages"]:checked')].map(el => el.value),
    countries_served: document.getElementById('countries_served').value.trim() || null,
    year_founded: yearVal ? parseInt(yearVal, 10) : null,
    employee_count: document.getElementById('employee_count').value || null,
    taking_new_projects: tnpVal === 'true' ? true : tnpVal === 'false' ? false : null,
    turnstile_token: tknEl?.value || '',
    is_suspect: isSuspect,
  };
}

// ================================================================
// Submit handler
// ================================================================
const form        = document.getElementById('submit-form');
const submitBtn   = document.getElementById('submit-btn');
const successEl   = document.getElementById('success-state');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  clearAllErrors();

  if (!validateForm()) {
    showBanner('Bitte korrigieren Sie die markierten Felder vor dem Absenden.');
    return;
  }

  const honeypotVal = form.querySelector('[name="website_url"]')?.value;
  const isSuspect   = Boolean(honeypotVal);

  submitBtn.disabled = true;
  submitBtn.textContent = 'Wird eingereicht…';

  try {
    const res  = await fetch('/api/submit-listing', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(collectPayload(isSuspect)),
    });
    const data = await res.json();

    if (!res.ok || data.error) {
      showBanner(data.error || 'Etwas ist schiefgelaufen. Bitte versuchen Sie es erneut.');
      submitBtn.disabled    = false;
      submitBtn.textContent = 'Eintrag einreichen';
    } else {
      form.classList.add('hidden');
      successEl.classList.remove('hidden');
      successEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  } catch {
    showBanner('Netzwerkfehler. Bitte prüfen Sie Ihre Verbindung und versuchen Sie es erneut.');
    submitBtn.disabled    = false;
    submitBtn.textContent = 'Eintrag einreichen';
  }
});

</script>
