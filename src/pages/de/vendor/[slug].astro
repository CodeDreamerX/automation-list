---
// Server-Side Rendering (SSR) - This page is rendered on-demand
// See STATIC_GENERATION_STRATEGY.md for details

export const prerender = false;

import { supabase } from '../../../lib/supabaseClient';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LogoBox from '../../../components/LogoBox.astro';
import { normalizeVendor } from '../../../lib/vendors/vendorUtils';
import { truncateDescription } from '../../../lib/vendors/vendorFormatters';
import { getBooleanEnvVar } from '../../../lib/env';
import { slugifyCountry } from '../../../lib/countryUtils';

// Helper function to parse logo background variant from logo URL
// Supports pattern: __{variant}.{ext} (e.g., logo__dark.svg)
// Also checks for common patterns in filename (e.g., logo_white.svg -> dark background)
function parseLogoVariant(logoUrl: string | null | undefined): "light" | "dark" | "neutral" | "brand" {
  if (!logoUrl) return "light";
  
  const url = logoUrl.toLowerCase();
  
  // Check for explicit variant pattern: __{variant}.{ext}
  const explicitVariantMatch = url.match(/__([a-z]+)\.(svg|png|jpg|jpeg|webp)$/);
  if (explicitVariantMatch) {
    const variant = explicitVariantMatch[1];
    const variantMap: Record<string, "light" | "dark" | "neutral" | "brand"> = {
      white: 'light',
      light: 'neutral',
      gray: 'neutral',
      dark: 'dark',
      brand: 'brand',
    };
    if (variantMap[variant]) {
      return variantMap[variant];
    }
  }
  
  // Check for common filename patterns
  // If filename contains "white", use dark background (white logo on dark bg)
  if (url.includes('_white') || url.includes('-white') || url.match(/white[._-]/)) {
    return 'dark';
  }
  
  // If filename contains "dark" or "black", use light background
  if (url.includes('_dark') || url.includes('-dark') || url.includes('_black') || url.includes('-black')) {
    return 'light';
  }
  
  // Default to light background
  return 'light';
}

// Helper function to get logo variant: use stored logo_background_variant if available, otherwise parse from logo URL
function getLogoVariant(vendor: any): "light" | "dark" | "neutral" | "brand" {
  // If vendor.logo_background_variant exists and is not null, use it directly
  // Database stores: 'light', 'neutral', 'dark', 'brand' (already in LogoBox format)
  const storedVariant = vendor.logo_background_variant;
  if (storedVariant && typeof storedVariant === 'string') {
    const validVariants: ("light" | "dark" | "neutral" | "brand")[] = ['light', 'dark', 'neutral', 'brand'];
    if (validVariants.includes(storedVariant as any)) {
      return storedVariant as "light" | "dark" | "neutral" | "brand";
    }
  }
  
  // Fallback to filename-based parsing
  return parseLogoVariant(vendor.logo_url);
}

// Fetch full vendor data by slug with vendor_categories JOIN
const { slug } = Astro.params;

const { data: vendor, error } = await supabase
  .from('vendors')
  .select(`
    *,
    vendor_categories (
      is_primary,
      categories:categories (
        id,
        slug,
        name_en,
        name_de
      )
    ),
    vendor_technologies (
      technologies:technologies (
        id,
        slug,
        name_en,
        name_de
      )
    ),
    vendor_industries (
      industries:industries (
        id,
        slug,
        name_en,
        name_de
      )
    ),
    vendor_certifications (
      certifications:certifications (
        id,
        slug,
        name,
        reference_url,
        category
      )
    ),
    vendor_countries (
      countries:countries (
        id,
        slug,
        name_en,
        name_de,
        flag_emoji
      )
    )
  `)
  .eq('slug', slug)
  .maybeSingle();

if (error) {
  console.error('Error fetching vendor:', error);
}

if (!vendor) {
  return Astro.redirect('/de/vendors');
}

// Normalize category, technology, and industry data shape
const normalizedVendor = normalizeVendor(vendor, {
  includeCategories: true,
  includeTechnologies: false,
  includeIndustries: false,
  includeCountries: true,
});
// Use language-specific description (DE: description_de, fallback to description_en if missing)
normalizedVendor.description_en = vendor.description_en || null;
normalizedVendor.description_de = vendor.description_de || null;
// Keep technologies, industries, and certifications as arrays for display
normalizedVendor.vendor_technologies = vendor.vendor_technologies || [];
normalizedVendor.vendor_industries = vendor.vendor_industries || [];
normalizedVendor.vendor_certifications = vendor.vendor_certifications || [];

const backUrl = "/de/vendors";

// Helper function to split comma-separated values into array
function splitValue(value: string | string[] | null | undefined): string[] {
  if (!value) return [];
  if (Array.isArray(value)) return value;
  return String(value).split(',').map(item => item.trim()).filter(Boolean);
}

// Helper function to format array or string values for display
function formatValue(value: string | string[] | null | undefined): string {
  if (!value) return '';
  if (Array.isArray(value)) {
    return value.join(', ');
  }
  return String(value);
}


// Determine plan status
const plan = normalizedVendor.plan || 'free';
const isFeatured = normalizedVendor.featured === true || plan === 'featured';
const disableProPaywall = getBooleanEnvVar('DISABLE_PRO_PAYWALL', false);
const hasPaidPlan = plan === 'pro' || isFeatured;
const hasProAccess = disableProPaywall || hasPaidPlan;
const isFree = plan === 'free' && !isFeatured;
const showUpgradeCta = isFree && !disableProPaywall;
const isOgMember = normalizedVendor.og_member === true;

// Build location string
function getLocation(): string {
  const parts: string[] = [];
  if (normalizedVendor.city) parts.push(normalizedVendor.city);
  if (normalizedVendor.region) parts.push(normalizedVendor.region);
  if (normalizedVendor.country) parts.push(normalizedVendor.country);
  return parts.join(', ');
}

const location = getLocation();

// Get primary category
const primaryCategory = normalizedVendor.vendor_categories?.find((vc: any) => vc.is_primary === true);
const primaryCategoryName = primaryCategory?.categories?.name_de || primaryCategory?.categories?.name_en;
const primaryCategorySlug = primaryCategory?.categories?.slug;

// Determine canonical URL
const canonicalUrl = normalizedVendor.canonical_url || `${Astro.site?.origin ?? Astro.url.origin}/de/vendor/${slug}`;

// Build JSON-LD Organization schema
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: normalizedVendor.name,
  ...(normalizedVendor.website && { url: normalizedVendor.website }),
  ...(normalizedVendor.logo_url && { logo: normalizedVendor.logo_url }),
  ...((normalizedVendor.description_de || normalizedVendor.description_en) && { 
    description: normalizedVendor.description_de || normalizedVendor.description_en 
  }),
  ...((normalizedVendor.city || normalizedVendor.country) && {
    address: {
      "@type": "PostalAddress",
      ...(normalizedVendor.city && { addressLocality: normalizedVendor.city }),
      ...(normalizedVendor.country && { addressCountry: normalizedVendor.country }),
    },
  }),
  ...(normalizedVendor.website && { sameAs: [normalizedVendor.website] }),
};

const organizationSchemaJson = JSON.stringify(organizationSchema);

// Build JSON-LD BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Startseite",
      item: `${Astro.url.origin}/de/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Anbieter",
      item: `${Astro.url.origin}/de/vendors`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: normalizedVendor.name,
      item: `${Astro.url.origin}/de/vendor/${slug}`,
    },
  ],
};

const breadcrumbSchemaJson = JSON.stringify(breadcrumbSchema);

// Build contextual breadcrumbs based on referrer or query parameters
// Check if user came from a technology or industry page
const referrer = Astro.request.headers.get('referer') || '';
const fromParam = Astro.url.searchParams.get('from');
let techSlugParam = Astro.url.searchParams.get('tech');
let industrySlugParam = Astro.url.searchParams.get('industry');

// Extract slug from referrer URL if not in query params
if (!techSlugParam && referrer.includes('/technology/')) {
  const techMatch = referrer.match(/\/technology\/([^\/\?]+)/);
  if (techMatch) {
    techSlugParam = techMatch[1];
  }
}

if (!industrySlugParam && referrer.includes('/industry/')) {
  const industryMatch = referrer.match(/\/industry\/([^\/\?]+)/);
  if (industryMatch) {
    industrySlugParam = industryMatch[1];
  }
}

let breadcrumbs: Array<{ label: string; href: string }> = [];

// Determine context from query params or referrer URL
const isFromTechnology = fromParam === 'technology' || referrer.includes('/technology/');
const isFromIndustry = fromParam === 'industry' || referrer.includes('/industry/');

if (isFromTechnology && techSlugParam) {
  // Fetch technology data for breadcrumb
  const { data: tech } = await supabase
    .from('technologies')
    .select('slug, name_en, name_de')
    .eq('slug', techSlugParam)
    .eq('is_active', true)
    .maybeSingle();
  
  if (tech) {
    const techName = tech.name_de || tech.name_en || techSlugParam;
    breadcrumbs = [
      { label: "Startseite", href: "/de/" },
      { label: "Technologien", href: "/de/technologies" },
      { label: techName, href: `/de/technology/${techSlugParam}` },
      { label: normalizedVendor.name, href: `/de/vendor/${slug}` },
    ];
  } else {
    // Fallback to default if technology not found
    breadcrumbs = [
      { label: "Startseite", href: "/de/" },
      { label: "Anbieter", href: "/de/vendors" },
      { label: normalizedVendor.name, href: `/de/vendor/${slug}` },
    ];
  }
} else if (isFromIndustry && industrySlugParam) {
  // Fetch industry data for breadcrumb
  const { data: industry } = await supabase
    .from('industries')
    .select('slug, name_en, name_de')
    .eq('slug', industrySlugParam)
    .eq('is_active', true)
    .maybeSingle();
  
  if (industry) {
    const industryName = industry.name_de || industry.name_en || industrySlugParam;
    breadcrumbs = [
      { label: "Startseite", href: "/de/" },
      { label: "Branchen", href: "/de/industries" },
      { label: industryName, href: `/de/industry/${industrySlugParam}` },
      { label: normalizedVendor.name, href: `/de/vendor/${slug}` },
    ];
  } else {
    // Fallback to default if industry not found
    breadcrumbs = [
      { label: "Startseite", href: "/de/" },
      { label: "Anbieter", href: "/de/vendors" },
      { label: normalizedVendor.name, href: `/de/vendor/${slug}` },
    ];
  }
} else {
  // Default breadcrumbs: Startseite -> Anbieter -> Vendor
  breadcrumbs = [
    { label: "Startseite", href: "/de/" },
    { label: "Anbieter", href: "/de/vendors" },
    { label: normalizedVendor.name, href: `/de/vendor/${slug}` },
  ];
}

// Determine title: use meta_title if available, otherwise fallback to vendor.name + " | Automation List"
const pageTitle = normalizedVendor.meta_title || `${normalizedVendor.name} | Automation List`;

// Determine description: use meta_description if available, otherwise fallback to truncated vendor.description_de (or description_en)
const pageDescription = normalizedVendor.meta_description || 
  ((normalizedVendor.description_de || normalizedVendor.description_en) ? truncateDescription(normalizedVendor.description_de || normalizedVendor.description_en, 160) : `Erfahren Sie mehr über ${normalizedVendor.name}, einen führenden Anbieter in der Industrieautomatisierung.`);

// Determine OG image: use vendor.logo_url if available, otherwise fallback to default
const origin = Astro.url.origin;
const image = normalizedVendor.logo_url || `${origin}/og/default.png`;

// Prepare technologies data
const allTechnologies = normalizedVendor.vendor_technologies || [];

// Prepare certifications data (M2M)
const allCertifications = normalizedVendor.vendor_certifications || [];

// Prepare languages data
const languages = normalizedVendor.languages ? splitValue(normalizedVendor.languages) : [];

// Prepare industries data
const allIndustries = normalizedVendor.vendor_industries || [];

// Prepare tags data
const tags = normalizedVendor.tags ? splitValue(normalizedVendor.tags) : [];

// Prepare categories data (show everywhere, not just for Pro)
const allCategories = normalizedVendor.vendor_categories || [];
const vendorDescription = normalizedVendor.description_de || normalizedVendor.description_en;
const descriptionWordCount = vendorDescription ? vendorDescription.trim().split(/\s+/).filter(Boolean).length : 0;
const shouldCollapseDescription = descriptionWordCount > 200;
---

<BaseLayout 
  title={pageTitle}
  description={pageDescription}
  ogImage={image}
  lang="de"
  breadcrumbs={breadcrumbs}
  meta={{ canonical: canonicalUrl }}
>
  <script slot="head" type="application/ld+json" set:html={organizationSchemaJson} />
  <script slot="head" type="application/ld+json" set:html={breadcrumbSchemaJson} />
  <style>
    .vendor-description-copy {
      line-height: 1.625;
    }

    .vendor-description-content[data-collapsible="true"][data-enhanced="true"] {
      position: relative;
      overflow: hidden;
      max-height: calc(1em * 1.625 * 4);
      transition: max-height 180ms ease;
    }

    .vendor-description-content[data-collapsible="true"][data-enhanced="true"]::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 2.75rem;
      background: linear-gradient(to bottom, rgba(255, 255, 255, 0), #fff);
      pointer-events: none;
      transition: opacity 180ms ease;
    }

    .vendor-description-content[data-expanded="true"]::after {
      opacity: 0;
    }
  </style>
  <div class={`container-px mx-auto max-w-4xl px-4 py-10 ${showUpgradeCta ? 'pb-28' : ''}`}>
    <a href={backUrl} class="text-sm text-brand-700 hover:text-brand-800 mb-6 inline-block">
      &larr; Zurück zu Anbietern
    </a>

    <!-- SECTION 1 - HEADER -->
    <div class={`mb-8 text-center ${isFeatured ? 'border-2 border-orange-300 rounded-lg p-6 bg-orange-50/30' : ''}`}>
      <div class="flex justify-center mb-4">
        <LogoBox 
          src={normalizedVendor.logo_url} 
          alt={normalizedVendor.logo_alt || `${normalizedVendor.name} Logo`}
          size="md"
          variant={getLogoVariant(normalizedVendor)}
          logoWidth={normalizedVendor.logo_width}
          logoHeight={normalizedVendor.logo_height}
        />
      </div>
      
      <h1 class="text-3xl font-bold text-gray-900 mb-3">{normalizedVendor.name}</h1>
      
      <!-- Badges -->
      <div class="flex flex-wrap justify-center gap-2 mb-4">
        {isFeatured && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-700">
            Featured Vendor
          </span>
        )}
        {hasPaidPlan && !isFeatured && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-700">
            Pro
          </span>
        )}
        {isOgMember && (
          <span class="inline-block px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
            OG Member - Preis für immer gesperrt
          </span>
        )}
      </div>

      <!-- Primary Category -->
      {primaryCategoryName && primaryCategorySlug && (
        <p class="text-sm text-gray-600 mb-2">
          <a 
            href={`/de/category/${primaryCategorySlug}`}
            class="inline-block px-2 py-1 text-xs font-medium bg-brand-50 text-brand-700 rounded hover:bg-brand-100 transition-colors"
          >
            {primaryCategoryName}
          </a>
        </p>
      )}

      {(normalizedVendor.city || normalizedVendor.region || normalizedVendor.country) && (
        <p class="text-sm text-gray-600 mb-4">
          {normalizedVendor.city}{normalizedVendor.city && (normalizedVendor.region || normalizedVendor.country) ? ', ' : ''}
          {normalizedVendor.region}{normalizedVendor.region && normalizedVendor.country ? ', ' : ''}
          {normalizedVendor.country && (
            <a
              href={`/de/country/${slugifyCountry(normalizedVendor.country)}`}
              class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
            >{normalizedVendor.country}</a>
          )}
        </p>
      )}

      {normalizedVendor.website && (
        <a 
          href={normalizedVendor.website} 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-block px-4 py-2 bg-black text-white rounded-md text-sm font-medium hover:bg-gray-900 transition"
        >
          Website besuchen &rarr;
        </a>
      )}
    </div>

    <!-- SECTION 2 - DESCRIPTION -->
    {vendorDescription && (
      <div class="mb-4">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Über</h2>
        <div
          id="vendor-description-de"
          class="vendor-description-content"
          data-collapsible={shouldCollapseDescription ? 'true' : 'false'}
          data-enhanced="false"
          data-expanded="false"
        >
          <p class="vendor-description-copy text-gray-700 text-sm">{vendorDescription}</p>
        </div>
        {shouldCollapseDescription && (
          <button
            type="button"
            class="vendor-description-toggle mt-3 inline-flex text-sm font-medium text-brand-700 hover:text-brand-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
            aria-controls="vendor-description-de"
            aria-expanded="false"
            data-label-more="Mehr lesen"
            data-label-less="Weniger anzeigen"
            hidden
          >
            Mehr lesen
          </button>
        )}
      </div>
    )}

    {normalizedVendor.specialization_text && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Was uns unterscheidet</h2>
        <p class="text-gray-700 text-sm leading-relaxed italic">{normalizedVendor.specialization_text}</p>
      </div>
    )}

    <!-- SECTION 3 - GRID BLOCKS -->
    {(allTechnologies.length > 0 || allCertifications.length > 0 || languages.length > 0 || allIndustries.length > 0 || tags.length > 0 || allCategories.length > 0) && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Technologies -->
        {allTechnologies.length > 0 && (
          <div class="border border-gray-200 rounded-lg p-4 flex flex-col min-h-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Technologien</h3>
            <div class="flex flex-wrap items-start gap-2">
              {(() => {
                const vt = allTechnologies[0];
                const tech = vt?.technologies;
                const techName = tech?.name_de || tech?.name_en;
                const techSlug = tech?.slug;
                return techName && techSlug ? (
                  <a
                    href={`/de/technology/${techSlug}`}
                    class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                  >
                    {techName}
                  </a>
                ) : null;
              })()}
              {hasProAccess ? (
                allTechnologies.slice(1).map((vt: any) => {
                  const tech = vt.technologies;
                  const techName = tech?.name_de || tech?.name_en;
                  const techSlug = tech?.slug;
                  if (!techName || !techSlug) return null;
                  return (
                    <a
                      href={`/de/technology/${techSlug}`}
                      class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                    >
                      {techName}
                    </a>
                  );
                })
              ) : (
                allTechnologies.slice(1).map((_: any, i: number) => (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-400 bg-gray-50 rounded border border-gray-100 select-none">
                    &#128274; Nur Pro
                  </span>
                ))
              )}
            </div>
          </div>
        )}

        <!-- Certifications -->
        {allCertifications.length > 0 && (
          <div class="border border-gray-200 rounded-lg p-4 flex flex-col min-h-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Zertifizierungen</h3>
            <div class="flex flex-wrap gap-2">
              {hasProAccess ? (
                allCertifications.map((vc: any) => {
                  const cert = vc.certifications;
                  if (!cert?.name) return null;
                  return cert.reference_url ? (
                    <a
                      href={cert.reference_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                    >
                      {cert.name}
                    </a>
                  ) : (
                    <span class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded">
                      {cert.name}
                    </span>
                  );
                })
              ) : (
                allCertifications.map((_: any, i: number) => (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-400 bg-gray-50 rounded border border-gray-100 select-none">
                    &#128274; Nur Pro
                  </span>
                ))
              )}
            </div>
          </div>
        )}

        <!-- Languages -->
        {languages.length > 0 && (
          <div class="border border-gray-200 rounded-lg p-4 flex flex-col min-h-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Sprachen</h3>
            <div class="flex flex-wrap gap-2">
              {hasProAccess ? (
                languages.map((lang) => (
                  <span class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded">
                    {lang}
                  </span>
                ))
              ) : (
                languages.map((_: string, i: number) => (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-400 bg-gray-50 rounded border border-gray-100 select-none">
                    &#128274; Nur Pro
                  </span>
                ))
              )}
            </div>
          </div>
        )}

        <!-- Industries -->
        {allIndustries.length > 0 && (
          <div class="border border-gray-200 rounded-lg p-4 flex flex-col min-h-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Branchen</h3>
            <div class="flex flex-wrap items-start gap-2">
              {(() => {
                const vi = allIndustries[0];
                const industry = vi?.industries;
                const industryName = industry?.name_de || industry?.name_en;
                const industrySlug = industry?.slug;
                return industryName && industrySlug ? (
                  <a
                    href={`/de/industry/${industrySlug}`}
                    class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                  >
                    {industryName}
                  </a>
                ) : null;
              })()}
              {hasProAccess ? (
                allIndustries.slice(1).map((vi: any) => {
                  const industry = vi.industries;
                  const industryName = industry?.name_de || industry?.name_en;
                  const industrySlug = industry?.slug;
                  if (!industryName || !industrySlug) return null;
                  return (
                    <a
                      href={`/de/industry/${industrySlug}`}
                      class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                    >
                      {industryName}
                    </a>
                  );
                })
              ) : (
                allIndustries.slice(1).map((_: any, i: number) => (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-400 bg-gray-50 rounded border border-gray-100 select-none">
                    &#128274; Nur Pro
                  </span>
                ))
              )}
            </div>
          </div>
        )}

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="border border-gray-200 rounded-lg p-4 flex flex-col min-h-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {hasProAccess ? (
                tags.map((tag) => (
                  <span class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded">
                    {tag}
                  </span>
                ))
              ) : (
                tags.map((_: string, i: number) => (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-400 bg-gray-50 rounded border border-gray-100 select-none">
                    &#128274; Nur Pro
                  </span>
                ))
              )}
            </div>
          </div>
        )}

        <!-- Categories -->
        {allCategories.length > 0 && (
          <div class="border border-gray-200 rounded-lg p-4 flex flex-col min-h-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Kategorien</h3>
            <div class="flex flex-wrap items-start gap-2">
              {allCategories.slice(0, 2).map((vc: any) => {
                const categoryName = vc.categories?.name_de || vc.categories?.name_en;
                const categorySlug = vc.categories?.slug;
                if (!categoryName || !categorySlug) return null;
                return (
                  <a
                    href={`/de/category/${categorySlug}`}
                    class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                  >
                    {categoryName}
                  </a>
                );
              })}
              {hasProAccess ? (
                allCategories.slice(2).map((vc: any) => {
                  const categoryName = vc.categories?.name_de || vc.categories?.name_en;
                  const categorySlug = vc.categories?.slug;
                  if (!categoryName || !categorySlug) return null;
                  return (
                    <a
                      href={`/de/category/${categorySlug}`}
                      class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                    >
                      {categoryName}
                    </a>
                  );
                })
              ) : (
                allCategories.slice(2).map((_: any, i: number) => (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-gray-400 bg-gray-50 rounded border border-gray-100 select-none">
                    &#128274; Nur Pro
                  </span>
                ))
              )}
            </div>
          </div>
        )}
      </div>
    )}

    <!-- SECTION 4 - COMPANY FACTS (always visible, values locked for free) -->
    {(normalizedVendor.year_founded || normalizedVendor.employee_count || normalizedVendor.hourly_rate || normalizedVendor.region || normalizedVendor.country || (normalizedVendor.vendor_countries && normalizedVendor.vendor_countries.length > 0) || (normalizedVendor.taking_new_projects !== null && normalizedVendor.taking_new_projects !== undefined)) && (
      <div class="border border-gray-200 rounded-lg p-6 mb-8 bg-gray-50">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Unternehmensfakten</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {normalizedVendor.year_founded && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Gründungsjahr</p>
              {hasProAccess ? (
                <p class="text-sm font-medium text-gray-900">{normalizedVendor.year_founded}</p>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {normalizedVendor.employee_count && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Mitarbeiter</p>
              {hasProAccess ? (
                <p class="text-sm font-medium text-gray-900">{normalizedVendor.employee_count}</p>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {normalizedVendor.hourly_rate && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Stundensatz</p>
              {hasProAccess ? (
                <p class="text-sm font-medium text-gray-900">{normalizedVendor.hourly_rate}</p>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {normalizedVendor.countries_served && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Tätigkeitsländer</p>
              <p class="text-sm font-medium text-gray-900">{normalizedVendor.countries_served}</p>
            </div>
          )}
          {normalizedVendor.taking_new_projects !== null && normalizedVendor.taking_new_projects !== undefined && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Neue Projekte</p>
              {hasProAccess ? (
                normalizedVendor.taking_new_projects ? (
                  <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-800 font-medium">Ja</span>
                ) : (
                  <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-gray-100 text-gray-600 font-medium">Derzeit nicht</span>
                )
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {(normalizedVendor.city || normalizedVendor.region || normalizedVendor.country) && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Standort</p>
              <p class="text-sm font-medium text-gray-900">
                {normalizedVendor.city}{normalizedVendor.city && (normalizedVendor.region || normalizedVendor.country) ? ', ' : ''}
                {normalizedVendor.region}{normalizedVendor.region && normalizedVendor.country ? ', ' : ''}
                {normalizedVendor.country && (
                  <a
                    href={`/de/country/${slugifyCountry(normalizedVendor.country)}`}
                    class="inline-block px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                  >{normalizedVendor.country}</a>
                )}
              </p>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- SECTION 5 - CONTACT CARD (always visible, values locked for free) -->
    {(normalizedVendor.email || normalizedVendor.phone || normalizedVendor.address || normalizedVendor.linkedin_url) && (
      <div class="border border-gray-200 rounded-lg p-6 mb-8">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Kontakt</h2>
        <div class="space-y-3">
          {normalizedVendor.email && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">E-Mail</p>
              {hasProAccess ? (
                <a href={`mailto:${normalizedVendor.email}`} class="text-sm text-brand-700 hover:text-brand-800">
                  {normalizedVendor.email}
                </a>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {normalizedVendor.phone && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Telefon</p>
              {hasProAccess ? (
                <a href={`tel:${normalizedVendor.phone}`} class="text-sm text-brand-700 hover:text-brand-800">
                  {normalizedVendor.phone}
                </a>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {normalizedVendor.address && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Adresse</p>
              {hasProAccess ? (
                <p class="text-sm text-gray-900">{normalizedVendor.address}</p>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
          {normalizedVendor.linkedin_url && (
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">LinkedIn</p>
              {hasProAccess ? (
                <a href={normalizedVendor.linkedin_url} target="_blank" rel="noopener noreferrer" class="text-sm text-brand-700 hover:text-brand-800">
                  LinkedIn-Profil ansehen &rarr;
                </a>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 select-none">&#128274; Nur Pro</span>
              )}
            </div>
          )}
        </div>
      </div>
    )}

    <!-- SECTION 6 - UPGRADE CTA (free only) -->
    {showUpgradeCta && (
      <div id="upgrade-cta" class="border border-gray-200 rounded-lg p-8 mb-8 text-center transition-all duration-300">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Vollständiges Profil freischalten</h3>
        <p class="text-sm text-gray-500 mb-6">
          Erhalten Sie Zugang zu allen Technologien, Branchen und Unternehmensdetails.
        </p>
        <a
          href="/de/pricing"
          class="inline-block rounded-md bg-orange-500 px-6 py-3 text-sm font-medium text-white transition hover:bg-orange-600"
        >
          Auf Pro upgraden - CHF 99/Jahr
        </a>
      </div>
    )}
    {normalizedVendor.updated_at && (
      <p class="text-xs text-gray-400 mt-8 text-center">
        Profil zuletzt aktualisiert: {new Date(normalizedVendor.updated_at).toLocaleDateString('de-DE', { month: 'long', year: 'numeric' })}
      </p>
    )}
  </div>
  <script>
    document.querySelectorAll<HTMLButtonElement>('.vendor-description-toggle').forEach((button) => {
      button.hidden = false;
      const controlsId = button.getAttribute('aria-controls');
      if (!controlsId) return;

      const content = document.getElementById(controlsId);
      if (!content) return;

      content.setAttribute('data-enhanced', 'true');

      button.addEventListener('click', () => {
        const expanded = button.getAttribute('aria-expanded') === 'true';
        const nextExpanded = !expanded;

        button.setAttribute('aria-expanded', String(nextExpanded));
        button.textContent = nextExpanded
          ? button.getAttribute('data-label-less') || 'Weniger anzeigen'
          : button.getAttribute('data-label-more') || 'Mehr lesen';
        content.setAttribute('data-expanded', String(nextExpanded));
        content.style.maxHeight = nextExpanded ? `${content.scrollHeight}px` : '';
      });
    });
  </script>
  {showUpgradeCta && (
    <div class="fixed inset-x-0 bottom-0 z-40 border-t border-gray-200 bg-white/95 shadow-[0_-4px_12px_rgba(15,23,42,0.08)] backdrop-blur">
      <div class="mx-auto flex h-14 max-w-4xl items-center justify-between gap-3 px-4">
        <p class="flex items-center gap-2 text-xs text-gray-700 sm:text-sm">
          <span aria-hidden="true">&#128274;</span>
          <span class="sm:hidden">Mit Pro freischalten &rarr;</span>
          <span class="hidden sm:inline">Ausgeblendete Details gibt es mit Pro.</span>
        </p>
        <a
          href="/de/pricing"
          class="inline-block rounded-md bg-orange-500 px-3 py-2 text-xs font-medium text-white transition hover:bg-orange-600 sm:px-4 sm:text-sm"
        >
          Upgrade
        </a>
      </div>
    </div>
  )}
  {showUpgradeCta && (
    <script>
      const cta = document.getElementById('upgrade-cta');
      const lockNodes = Array.from(document.querySelectorAll('span')).filter((node) =>
        (node.textContent || '').trim().startsWith('\uD83D\uDD12')
      );

      const focusUpgradeCta = () => {
        if (!cta) return;
        cta.scrollIntoView({ behavior: 'smooth', block: 'center' });
        cta.classList.add('ring-2', 'ring-black', 'ring-offset-2');
        window.setTimeout(() => {
          cta.classList.remove('ring-2', 'ring-black', 'ring-offset-2');
        }, 1400);
      };

      lockNodes.forEach((node) => {
        node.classList.add('cursor-pointer');
        node.setAttribute('role', 'button');
        node.setAttribute('tabindex', '0');
        node.setAttribute('aria-label', 'Upgrade-Optionen anzeigen');
        node.addEventListener('click', focusUpgradeCta);
        node.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            focusUpgradeCta();
          }
        });
      });
    </script>
  )}
</BaseLayout>
