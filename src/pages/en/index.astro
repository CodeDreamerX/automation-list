---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabaseClient";
import { getCached, setCached } from "../../lib/cache";
import { isFeatured } from "../../lib/isFeatured";
import HowItWorks from "../../components/HowItWorks.astro";
import PageHero from "../../components/PageHero.astro";
import WhyThisDirectory from "../../components/WhyThisDirectory.astro";
import SearchForm from "../../components/SearchForm.astro";
import CategoryGrid from "../../components/CategoryGrid.astro";
import IndustryGrid from "../../components/IndustryGrid.astro";
import FeaturedVendors from "../../components/FeaturedVendors.astro";
import { normalizeVendors } from "../../lib/vendors/vendorUtils";
import ExploreCTA from "../../components/ExploreCTA.astro";
import RecentlyAdded from "../../components/RecentlyAdded.astro";
import { getIndustries } from "../../lib/getIndustries";
import { getCountryNameMap } from "../../lib/countryUtils";
import type { VendorWithRelations } from "../../types/vendor";
import type { Industry } from "../../types/industry";
import { formatTechnologies as formatTechnologiesShared, truncateDescription } from "../../lib/vendors/vendorFormatters";

// --- Featured vendors (300s) ---
let featuredVendors = getCached<VendorWithRelations[]>('home:featured-vendors');
if (!featuredVendors) {
  const now = new Date().toISOString();

  const { data: proVendors } = await supabase
    .from("vendors")
    .select(`
      *,
      vendor_categories (
        is_primary,
        categories:categories (
          name_en,
          name_de
        )
      ),
      vendor_countries (
        countries:countries (
          name_en,
          name_de
        )
      ),
      vendor_technologies (
        technologies:technologies (
          name_en,
          name_de
        )
      )
    `)
    .eq('plan', 'pro')
    .order('priority', { ascending: true, nullsFirst: false })
    .limit(6);

  const { data: featuredVendorsData } = await supabase
    .from("vendors")
    .select(`
      *,
      vendor_categories (
        is_primary,
        categories:categories (
          name_en,
          name_de
        )
      ),
      vendor_countries (
        countries:countries (
          name_en,
          name_de
        )
      ),
      vendor_technologies (
        technologies:technologies (
          name_en,
          name_de
        )
      )
    `)
    .eq('featured', true)
    .gt('featured_until', now)
    .neq('plan', 'deactivated')
    .order('priority', { ascending: true, nullsFirst: false })
    .limit(6);

  const vendorMap = new Map();
  [...(proVendors || []), ...(featuredVendorsData || [])].forEach(v => {
    if (!vendorMap.has(v.id)) vendorMap.set(v.id, v);
  });
  const combined = normalizeVendors(Array.from(vendorMap.values()));
  combined.sort((a, b) => (a.priority || 999) - (b.priority || 999));
  featuredVendors = combined.slice(0, 6);
  setCached('home:featured-vendors', featuredVendors, 300);
}

// --- Fallback vendors (300s) ---
if (featuredVendors.length === 0) {
  let fallback = getCached<VendorWithRelations[]>('home:fallback-vendors');
  if (!fallback) {
    const { data: fallbackData } = await supabase
      .from("vendors")
      .select(`
        *,
        vendor_categories (
          is_primary,
          categories:categories (
            name_en,
            name_de
          )
        ),
        vendor_countries (
          countries:countries (
            name_en,
            name_de
          )
        ),
        vendor_technologies (
          technologies:technologies (
            name_en,
            name_de
          )
        )
      `)
      .neq('plan', 'deactivated')
      .limit(6);
    const normalizedFallback = normalizeVendors(fallbackData || []);
    fallback = [...normalizedFallback].sort(() => Math.random() - 0.5).slice(0, 6);
    setCached('home:fallback-vendors', fallback, 300);
  }
  featuredVendors = fallback;
}

const countryNameMap = await getCountryNameMap(supabase, getCached, setCached);

// Wrapper function to match existing call signature (English page uses lang="en")
function formatTechnologies(vendor: VendorWithRelations): string {
  return formatTechnologiesShared(vendor, "en");
}

// --- Categories (3600s) ---
let dbCategories = getCached<any[]>('home:categories');
if (!dbCategories) {
  const { data } = await supabase
    .from("categories")
    .select("id, slug, name_en, name_de, description_en, description_de, card_description_en, card_description_de, icon_name")
    .eq("is_active", true)
    .order("order_index", { ascending: true });
  dbCategories = data || [];
  setCached('home:categories', dbCategories, 3600);
}

// --- Category counts (300s) ---
let categoryVendorCounts = getCached<any[]>('home:category-counts');
if (!categoryVendorCounts) {
  const { data } = await supabase
    .from("category_vendor_counts")
    .select("category_id, vendor_count");
  categoryVendorCounts = data || [];
  setCached('home:category-counts', categoryVendorCounts, 300);
}

const categoryCountMap = new Map<string, number>();
categoryVendorCounts.forEach((item: any) => {
  if (item.category_id) categoryCountMap.set(item.category_id, item.vendor_count || 0);
});

const categories = dbCategories.map(cat => ({
  slug: cat.slug || '',
  icon_name: cat.icon_name || '',
  name_en: cat.name_en || '',
  name_de: cat.name_de || '',
  description_en: cat.description_en || '',
  description_de: cat.description_de || '',
  card_description_en: cat.card_description_en || '',
  card_description_de: cat.card_description_de || '',
  count: cat.id ? (categoryCountMap.get(cat.id) || 0) : 0,
})).filter(cat => cat.slug && (cat.name_en || cat.name_de));

// --- Total vendor count (300s) ---
let totalVendorCount = getCached<number>('home:total-vendor-count');
if (totalVendorCount === null) {
  const { count } = await supabase
    .from("vendors")
    .select("*", { count: "exact", head: true })
    .neq("plan", "deactivated");
  totalVendorCount = count ?? 0;
  setCached('home:total-vendor-count', totalVendorCount, 300);
}

// --- Country count (3600s) ---
let countryCount = getCached<number>('home:countries-count');
if (countryCount === null) {
  const { count } = await supabase
    .from("countries")
    .select("*", { count: "exact", head: true })
    .eq("is_active", true);
  countryCount = count ?? 0;
  setCached('home:countries-count', countryCount, 3600);
}

// --- Industries (3600s, locale-specific) ---
let allIndustries = getCached<Industry[]>('home:industries:en');
if (!allIndustries) {
  allIndustries = await getIndustries({ lang: "en", activeOnly: true });
  setCached('home:industries:en', allIndustries, 3600);
}

// --- Industry counts (300s) ---
let industryVendorCounts = getCached<any[]>('home:industry-counts');
if (!industryVendorCounts) {
  const { data } = await supabase
    .from("industry_vendor_counts")
    .select("industry_id, vendor_count");
  industryVendorCounts = data || [];
  setCached('home:industry-counts', industryVendorCounts, 300);
}

const industryCountMap = new Map<string, number>();
industryVendorCounts.forEach((item: any) => {
  if (item.industry_id) industryCountMap.set(item.industry_id, item.vendor_count || 0);
});

const industries = allIndustries.slice(0, 12).map(industry => ({
  ...industry,
  count: industry.id ? (industryCountMap.get(industry.id) || 0) : 0,
}));

// Build WebSite structured data with SearchAction
// Use production domain for schema.org URLs
const productionOrigin = Astro.site?.origin ?? Astro.url.origin;
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": `${productionOrigin}/en/`,
  "name": "Automation List",
  "description": "Vendor-neutral directory of industrial automation companies. Compare system integrators, OEMs, and automation experts worldwide.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${productionOrigin}/en/vendors?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const websiteSchemaJson = JSON.stringify(websiteSchema);
const activeCategoryCount = categories.length;
const activeCountryCount = countryCount ?? 0;
const dynamicMetaDescription = `Find and compare verified industrial automation vendors worldwide — system integrators, MES specialists, robotics integrators, machine builders, and more. Browse ${activeCategoryCount} categories across ${activeCountryCount} countries.`;

---

<BaseLayout 
  title="Industrial Automation Vendors Directory | Automation-List"
  description={dynamicMetaDescription}
  canonical="https://www.automation-list.com/en/"
  ogUrl="https://www.automation-list.com/en/"
  ogImage="https://www.automation-list.com/og/default.png"
  lang="en"
>
  <script slot="head" type="application/ld+json" set:html={websiteSchemaJson} />
  <PageHero
    title="Industrial Automation Vendors Directory"
    description="The vendor-neutral automation directory built by engineers — not agencies. Find and compare system integrators, OEMs, and specialists worldwide."
    vendorCount={totalVendorCount}
    vendorCountLabel="verified automation vendors listed"
    countryCount={countryCount}
    countriesHref="/en/countries"
    primaryButtonText="Browse Directory →"
    primaryButtonHref="/en/vendors"
    secondaryButtonText="Add Your Company for Free →"
    secondaryButtonHref="/en/submit-listing"
    secondaryMicroCopy="No credit card required"
  />

  <SearchForm
    action="/en/vendors"
    placeholder="Search by name, capability, or keyword"
  />

  <WhyThisDirectory />

  <section class="container-px mx-auto max-w-7xl py-4 md:py-6">
    <p class="text-sm md:text-base text-gray-700 leading-relaxed">
      Automation-List is a vendor-neutral directory of verified industrial automation companies, built for engineers and procurement teams who need to find the right partner fast. Browse system integrators, MES specialists, robotics integrators, machine builders, SCADA providers, and more — filtered by country, industry, and technology platform. Every profile is manually reviewed and includes technology stack, industry focus, and service scope. No sponsored rankings. No agency curation. Just the vendors that actually do the work.
    </p>
  </section>

  <CategoryGrid categories={categories} lang="en" />

  <IndustryGrid industries={industries} lang="en" />

  <HowItWorks />

  <FeaturedVendors
    vendors={featuredVendors}
    viewAllHref="/en/vendors"
    vendorHrefPrefix="/en/vendor"
    lang="en"
    countryNameMap={countryNameMap}
    formatTechnologies={formatTechnologies}
    truncateDescription={truncateDescription}
    isFeatured={isFeatured}
  />

  <RecentlyAdded lang="en" />

  <ExploreCTA />
</BaseLayout>



