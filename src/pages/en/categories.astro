---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryGrid from "../../components/CategoryGrid.astro";
import { supabase } from "../../lib/supabaseClient";
import { linkifyText } from "../../lib/linkify";
import { getKeywordMap } from "../../lib/keyword-map";


// Fetch active categories from database
const { data: dbCategories } = await supabase
  .from("categories")
  .select("id, slug, name_en, name_de, description_en, description_de, card_description_en, card_description_de, icon_name")
  .eq("is_active", true)
  .order("order_index", { ascending: true });

// Fetch vendor counts from materialized view
const { data: categoryVendorCounts } = await supabase
  .from("category_vendor_counts")
  .select("category_id, vendor_count");

// Create a map of category ID to vendor count
const countMap = new Map<string, number>();
(categoryVendorCounts || []).forEach((item: any) => {
  if (item.category_id) {
    countMap.set(item.category_id, item.vendor_count || 0);
  }
});

// Map database categories with counts from materialized view
const categories = (dbCategories || []).map(cat => ({
  slug: cat.slug || '',
  icon_name: cat.icon_name || '',
  name_en: cat.name_en || '',
  name_de: cat.name_de || '',
  description_en: cat.description_en || '',
  description_de: cat.description_de || '',
  card_description_en: cat.card_description_en || '',
  card_description_de: cat.card_description_de || '',
  count: cat.id ? (countMap.get(cat.id) || 0) : 0,
})).filter(cat => cat.slug && (cat.name_en || cat.name_de)); // Filter out categories without slug or names

// Build linkified descriptions, excluding each card's own self-link (URL-based filter).
const baseKeywordMap = getKeywordMap('en');
const linkifiedDescriptions: Record<string, string> = {};
for (const cat of categories) {
  if (!cat.card_description_en?.trim()) continue;
  const cardMap = new Map<string, string>([...baseKeywordMap].filter(([_, url]) => url !== `/en/category/${cat.slug}`));
  linkifiedDescriptions[cat.slug] = linkifyText(cat.card_description_en, cardMap, { minWordGap: 10, linkClass: "text-blue-600 hover:underline pointer-events-auto relative z-10" });
}

// Generate dynamic description from actual categories
const categoryNames = categories
  .slice(0, 6) // Limit to first 6 categories
  .map(cat => cat.name_en)
  .filter(Boolean);
const description = categoryNames.length > 0
  ? `Browse industrial automation categories including ${categoryNames.join(', ')}${categoryNames.length < categories.length ? ', and more.' : '.'}`
  : "Browse industrial automation categories and discover vendors in your area of expertise.";

// Build breadcrumbs
const breadcrumbs = [
  { label: "Home", href: "/en/" },
  { label: "Categories", href: "/en/categories" },
];

---

<BaseLayout 
  title="Industrial Automation Categories | Automation List"
  description={description}
  lang="en"
  breadcrumbs={breadcrumbs}
>
  <CategoryGrid title="Browse by Category" description={description} categories={categories} lang="en" headingLevel="h1" linkifiedDescriptions={linkifiedDescriptions} />
</BaseLayout>

