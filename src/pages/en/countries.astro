---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CountryGrid from '../../components/CountryGrid.astro';
import { supabase } from '../../lib/supabaseClient';

// Fetch active countries
const { data: countriesRaw } = await supabase
  .from('countries')
  .select('id, slug, name_en, name_de, card_description_en, card_description_de, flag_emoji')
  .eq('is_active', true)
  .order('order_index', { ascending: true, nullsFirst: false })
  .order('name_en', { ascending: true });

// Fetch vendor counts from the same view the country detail pages use
const { data: countRows } = await supabase
  .from('country_vendor_counts')
  .select('country, vendor_count');

const countMap = new Map<string, number>();
(countRows || []).forEach((row: any) => {
  if (row.country) countMap.set(row.country.toLowerCase(), row.vendor_count || 0);
});

const countries = (countriesRaw || []).map((c) => ({
  slug: c.slug,
  name: c.name_en,
  card_description_en: c.card_description_en,
  card_description_de: c.card_description_de,
  flag_emoji: c.flag_emoji,
  vendor_count: countMap.get((c.name_en || '').toLowerCase()) || 0,
}))
  .filter((c) => (c.vendor_count || 0) > 0)
  .sort((a, b) => {
    if ((b.vendor_count || 0) !== (a.vendor_count || 0)) {
      return (b.vendor_count || 0) - (a.vendor_count || 0);
    }
    return (a.name || '').localeCompare(b.name || '');
  });

const introDescription = "The global industrial automation landscape is shaped by regional strengths — from Switzerland's precision manufacturing heritage and Germany's deep MES and SCADA ecosystem to the Nordic countries' leadership in robotics and digitalization, and beyond. Choosing the right automation partner often depends on geographic proximity, local language capability, and familiarity with regional regulations such as machinery directives, GMP requirements in pharma, or food safety standards like IFS and BRC. A vendor based in your market understands local supply chains, can provide on-site support, and navigates the regulatory environment with confidence. Browse automation vendors by country to find system integrators, MES specialists, SCADA providers, robotics integrators, and panel builders with proven expertise in your region. Each country page shows verified vendors filterable by category, technology, and industry.";
const metaDescription = "Find industrial automation vendors worldwide. Browse by country to discover system integrators, MES specialists, SCADA providers and robotics integrators near you.";
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteOrigin}/en/` },
    { "@type": "ListItem", position: 2, name: "Countries", item: `${siteOrigin}/en/countries` },
  ],
};

const countriesItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Automation Vendors by Country",
  numberOfItems: countries.length,
  itemListElement: countries.map((country, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: country.name,
    url: `${siteOrigin}/en/country/${country.slug}`,
  })),
};

const breadcrumbs = [
  { label: 'Home', href: '/en/' },
  { label: 'Countries', href: '/en/countries' },
];
---

<BaseLayout
  title="Automation Vendors by Country | Automation List"
  description={metaDescription}
  lang="en"
  breadcrumbs={breadcrumbs}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(countriesItemListSchema)} />

  <CountryGrid title="Browse by Country" description={introDescription} countries={countries} lang="en" headingLevel="h1">
    <p slot="belowDescription" class="text-sm text-gray-600 mb-6 md:mb-8 text-center">
      You can also browse vendors by <a href="/en/categories" class="underline hover:no-underline">category</a>, <a href="/en/technologies" class="underline hover:no-underline">technology</a>, or <a href="/en/industries" class="underline hover:no-underline">industry</a>.
    </p>
  </CountryGrid>
</BaseLayout>
