---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabaseClient";

const [
  { data: catData },
  { data: techData },
  { data: indData },
  { data: certData },
] = await Promise.all([
  supabase.from('categories').select('slug, name_en').eq('is_active', true).order('name_en'),
  supabase.from('technologies').select('slug, name_en').eq('is_active', true).order('name_en'),
  supabase.from('industries').select('slug, name_en').eq('is_active', true).order('name_en'),
  supabase.from('certifications').select('slug, name').order('name'),
]);

const categories = (catData ?? []).map(r => ({ slug: r.slug, name: r.name_en }));
const technologies = (techData ?? []).map(r => ({ slug: r.slug, name: r.name_en }));
const industries = (indData ?? []).map(r => ({ slug: r.slug, name: r.name_en }));
const certifications = (certData ?? []).map(r => ({ slug: r.slug, name: r.name }));

const LANGUAGES = [
  'English', 'German', 'French', 'Italian', 'Spanish',
  'Dutch', 'Polish', 'Czech', 'Romanian', 'Hungarian', 'Portuguese',
];
---

<BaseLayout
  title="Submit Your Company | Automation List"
  description="Submit your industrial automation company to Automation List. Get discovered by engineers and procurement teams worldwide."
  lang="en"
>
  <div class="max-w-2xl mx-auto px-4 py-12 md:py-16">

    <!-- Scope notice -->
    <div class="mb-6 rounded-xl border border-blue-200 bg-blue-50/60 px-4 py-3 text-sm text-blue-900">
      <p class="leading-relaxed">
        <strong>Is your company a fit?</strong> This directory covers industrial automation vendors, including MES, SCADA, PLC, DCS, robotics, process control, and related OT/manufacturing technology.
        <span class="mt-1 block font-semibold">IT/business process automation (RPA, AI agents, workflow tools) is out of scope. AI applied to industrial or manufacturing processes is welcome.</span>
      </p>
    </div>

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Submit Your Company</h1>
      <p class="text-gray-600 text-sm leading-relaxed">
        Get your company listed in the Automation List directory. Fill in the required fields and optionally add more details to speed up review.
        Listings are reviewed within 1–2 business days.
      </p>
    </div>

    <!-- Success state (hidden until form submits) -->
    <div id="success-state" class="hidden bg-green-50 border border-green-200 rounded-xl px-6 py-10 text-center">
      <div class="text-3xl text-green-500 mb-3">✓</div>
      <h2 class="text-lg font-semibold text-green-800 mb-2">Listing submitted!</h2>
      <p class="text-green-700 text-sm max-w-sm mx-auto">
        Your listing has been submitted and is under review. We'll be in touch within 1–2 business days.
      </p>
    </div>

    <!-- Error banner -->
    <div id="error-banner" class="hidden mb-6 flex items-start gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm" role="alert">
      <span id="error-message"></span>
    </div>

    <!-- ==================== FORM ==================== -->
    <form id="submit-form" novalidate>

      <!-- Honeypot: visually hidden, bots may fill it -->
      <div aria-hidden="true" style="position:absolute;opacity:0;pointer-events:none;overflow:hidden;height:0;width:0;left:-9999px;">
        <label>Leave this empty<input type="text" name="website_url" tabindex="-1" autocomplete="off" /></label>
      </div>

      <!-- ========== SECTION 1: Required ========== -->
      <div class="bg-white border border-gray-200 rounded-xl p-6 space-y-5">
        <h2 class="text-sm font-semibold text-gray-900 border-b border-gray-100 pb-3 uppercase tracking-wide">
          Company Details
          <span class="text-xs font-normal text-red-500 ml-1 normal-case tracking-normal">* required</span>
        </h2>

        <!-- Company Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            Company Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
            placeholder="Acme Automation GmbH"
          />
          <p id="name-error" class="hidden mt-1 text-xs text-red-600">Company name is required</p>
        </div>

        <!-- Website -->
        <div>
          <label for="website" class="block text-sm font-medium text-gray-700 mb-1">
            Website <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="website"
            name="website"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
            placeholder="https://example.com"
          />
          <p id="website-error" class="hidden mt-1 text-xs text-red-600">A valid website URL is required</p>
        </div>

        <!-- Contact Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Contact Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
            placeholder="hello@example.com"
          />
          <p id="email-error" class="hidden mt-1 text-xs text-red-600">A valid email address is required</p>
        </div>

        <!-- Country (searchable single-select) -->
        <div id="country-field">
          <label for="country-input" class="block text-sm font-medium text-gray-700 mb-1">
            Country <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <input
              type="text"
              id="country-input"
              class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
              placeholder="Type to search countries..."
              autocomplete="off"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false"
              aria-controls="country-dropdown"
            />
            <input type="hidden" id="country-value" name="country" />
            <div
              id="country-dropdown"
              role="listbox"
              class="hidden absolute z-30 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-52 overflow-y-auto text-sm"
            ></div>
          </div>
          <p id="country-error" class="hidden mt-1 text-xs text-red-600">Please select a country from the list</p>
        </div>

        <!-- Categories (checkbox grid) -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Categories <span class="text-red-500">*</span>
            <span class="font-normal text-gray-400 ml-1">(select all that apply)</span>
          </label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
            {categories.map((cat) => (
              <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                <input
                  type="checkbox"
                  name="category_slugs"
                  value={cat.slug}
                  class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0"
                />
                <span>{cat.name}</span>
              </label>
            ))}
          </div>
          <p id="categories-error" class="hidden mt-2 text-xs text-red-600">Please select at least one category</p>
        </div>

        <!-- Description (English) -->
        <div>
          <label for="description_en" class="block text-sm font-medium text-gray-700 mb-1">
            Description <span class="text-red-500">*</span>
            <span class="font-normal text-gray-400 ml-1">(English)</span>
          </label>
          <textarea
            id="description_en"
            name="description_en"
            rows="4"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white resize-y"
            placeholder="Describe your company, specialisation, and what makes you stand out..."
          ></textarea>
          <p id="description_en-error" class="hidden mt-1 text-xs text-red-600">An English description is required</p>
        </div>

        <!-- Description (German) — optional -->
        <div>
          <label for="description_de" class="block text-sm font-medium text-gray-700 mb-1">
            Beschreibung
            <span class="font-normal text-gray-400 ml-1">(Deutsch, optional)</span>
          </label>
          <textarea
            id="description_de"
            name="description_de"
            rows="4"
            class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white resize-y"
            placeholder="Beschreiben Sie Ihr Unternehmen und Ihre Dienstleistungen auf Deutsch..."
          ></textarea>
        </div>

      </div>
      <!-- end Section 1 -->

      <!-- ========== SECTION 2: Optional / Collapsible ========== -->
      <div class="mt-4">
        <button
          type="button"
          id="section2-toggle"
          class="w-full flex items-center justify-between px-4 py-3 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl text-sm font-medium text-gray-700 transition-colors text-left"
        >
          <span id="section2-label">+ Add more details — the more you provide, the faster your listing goes live</span>
          <svg
            id="section2-chevron"
            class="w-4 h-4 text-gray-400 transition-transform duration-200 flex-shrink-0 ml-3"
            viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
          >
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>

        <div id="section2-content" class="hidden mt-3 bg-white border border-gray-200 rounded-xl p-6 space-y-6">

          <!-- City / Region / Address -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="city" class="block text-sm font-medium text-gray-700 mb-1">City</label>
              <input type="text" id="city" name="city" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="Munich" />
            </div>
            <div>
              <label for="region" class="block text-sm font-medium text-gray-700 mb-1">Region / State</label>
              <input type="text" id="region" name="region" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="Bavaria" />
            </div>
            <div class="sm:col-span-2">
              <label for="address" class="block text-sm font-medium text-gray-700 mb-1">Street address</label>
              <input type="text" id="address" name="address" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="Street, number, postal code (optional)" autocomplete="street-address" />
            </div>
          </div>

          <!-- Phone / LinkedIn -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
              <input type="text" id="phone" name="phone" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="+49 89 ..." />
            </div>
            <div>
              <label for="linkedin_url" class="block text-sm font-medium text-gray-700 mb-1">LinkedIn URL</label>
              <input type="url" id="linkedin_url" name="linkedin_url" class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white" placeholder="https://linkedin.com/company/..." />
            </div>
          </div>

          <!-- Technologies -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Technologies / Platforms</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {technologies.map((tech) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="technology_slugs" value={tech.slug} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{tech.name}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Industries -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Industries Served</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {industries.map((ind) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="industry_slugs" value={ind.slug} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{ind.name}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Certifications -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Certifications</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {certifications.map((cert) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="certification_slugs" value={cert.slug} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{cert.name}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Languages -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Service Languages</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
              {LANGUAGES.map((lang) => (
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer hover:text-gray-900 py-0.5">
                  <input type="checkbox" name="languages" value={lang} class="rounded border-gray-300 text-brand-600 focus:ring-brand-300 shrink-0" />
                  <span>{lang}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Countries served (search + tags; stored as English names for review) -->
          <div id="countries-served-field">
            <label for="cs-input" class="block text-sm font-medium text-gray-700 mb-1">Countries served</label>
            <p class="text-xs text-gray-500 mb-2">Add every country where you deliver projects (search and pick from the list).</p>
            <div id="cs-tags" class="flex flex-wrap gap-1.5 mb-2 min-h-0"></div>
            <div class="relative">
              <input
                type="text"
                id="cs-input"
                class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
                placeholder="Type to search countries…"
                autocomplete="off"
                aria-autocomplete="list"
                aria-expanded="false"
                aria-controls="cs-dropdown"
              />
              <div
                id="cs-dropdown"
                role="listbox"
                class="hidden absolute z-30 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-52 overflow-y-auto text-sm"
              ></div>
            </div>
          </div>

          <!-- Year Founded / Employee Count -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="year_founded" class="block text-sm font-medium text-gray-700 mb-1">Year Founded</label>
              <input
                type="number"
                id="year_founded"
                name="year_founded"
                min="1800"
                max="2099"
                class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
                placeholder="2005"
              />
            </div>
            <div>
              <label for="employee_count" class="block text-sm font-medium text-gray-700 mb-1">Company Size</label>
              <select
                id="employee_count"
                name="employee_count"
                class="sl-input w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-300 bg-white"
              >
                <option value="">Select...</option>
                <option value="1-10">1–10 employees</option>
                <option value="11-50">11–50 employees</option>
                <option value="51-200">51–200 employees</option>
                <option value="201-500">201–500 employees</option>
                <option value="500+">500+ employees</option>
              </select>
            </div>
          </div>

          <!-- Taking new projects -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Currently taking new projects?</label>
            <div class="flex gap-2 flex-wrap" id="new-projects-toggle">
              <button type="button" data-value="true"  class="toggle-opt px-4 py-1.5 text-sm border border-gray-300 rounded-full text-gray-600 hover:border-gray-500 transition-colors">Yes</button>
              <button type="button" data-value="false" class="toggle-opt px-4 py-1.5 text-sm border border-gray-300 rounded-full text-gray-600 hover:border-gray-500 transition-colors">No</button>
              <button type="button" data-value=""      class="toggle-opt px-4 py-1.5 text-sm border border-gray-300 rounded-full text-gray-600 hover:border-gray-500 transition-colors">Not specified</button>
            </div>
            <input type="hidden" id="taking-new-projects" value="" />
          </div>

        </div>
        <!-- end section2-content -->
      </div>
      <!-- end Section 2 -->

      <!-- Submit -->
      <div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-3">
        <button
          type="submit"
          id="submit-btn"
          class="px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Submit Listing
        </button>
        <p class="text-xs text-gray-400">
          By submitting, you confirm this information is accurate. Listings are manually reviewed before going live.
        </p>
      </div>

    </form>
    <!-- end form -->

  </div>
</BaseLayout>

<script>
  import { initSubmitListing } from '../../scripts/submit-listing-client';
  import { ISO_COUNTRIES_EN } from '../../scripts/submit-listing-country-data';
  initSubmitListing({
    country: { mode: 'en', countries: ISO_COUNTRIES_EN },
    countriesServed: { mode: 'en', countries: ISO_COUNTRIES_EN },
    strings: {
      countryNoResults: 'No results',
      section2Hide: '− Hide extra details',
      section2Show: '+ Add more details — the more you provide, the faster your listing goes live',
      validateBanner: 'Please fix the highlighted fields before submitting.',
      submitSubmitting: 'Submitting…',
      submitButton: 'Submit Listing',
      errorGeneric: 'Something went wrong. Please try again.',
      errorNetwork: 'Network error. Please check your connection and try again.',
    },
  });
</script>
