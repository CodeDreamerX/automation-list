---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

---

<BaseLayout
  title="Contact - Automation List"
  description="Get in touch with Automation List for questions or partnership inquiries."
  lang="en"
>
  <section class="py-16 md:py-24 bg-white">
    <div class="container-px mx-auto max-w-3xl">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Contact Us
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed">
          Have a question or partnership inquiry? We'd love to hear from you.
        </p>
      </div>

      <div class="card">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">
          Get in Touch
        </h2>
        <p class="text-gray-600 mb-6">
          For general inquiries or partnership opportunities, please reach out to us via email.
        </p>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-gray-500 uppercase tracking-wide mb-2">Email</p>
            <a href="mailto:contact@automation-list.com" class="text-lg text-brand-600 hover:text-brand-700 hover:underline font-medium">
              contact@automation-list.com
            </a>
          </div>
          <div class="pt-4 border-t border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 mb-3">What can we help you with?</h3>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-start">
                <span class="text-brand-600 mr-2">•</span>
                <span>Partnership and collaboration opportunities</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-600 mr-2">•</span>
                <span>General questions and feedback</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-600 mr-2">•</span>
                <span>Data correction or removal requests</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>