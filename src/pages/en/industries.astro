---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import IndustryGrid from "../../components/IndustryGrid.astro";
import { getIndustries } from "../../lib/getIndustries";
import { supabase } from "../../lib/supabaseClient";

// Fetch active industries from database
const allIndustries = await getIndustries({ lang: "en", activeOnly: true });

// Fetch vendor counts from materialized view
const { data: industryVendorCounts } = await supabase
  .from("industry_vendor_counts")
  .select("industry_id, vendor_count");

const industryCountMap = new Map<string, number>();
(industryVendorCounts || []).forEach((item: any) => {
  if (item.industry_id) {
    industryCountMap.set(item.industry_id, item.vendor_count || 0);
  }
});

// Map industries with vendor counts
const industries = allIndustries.map((industry) => ({
  ...industry,
  count: industry.id ? (industryCountMap.get(industry.id) || 0) : 0,
}));

const description =
  "Automation requirements differ significantly across industries. A food manufacturer needs hygienic design, CIP/SIP integration, and traceability. A pharma plant needs GMP validation, electronic batch records, and 21 CFR Part 11 compliance. An automotive line needs high-speed robotics, vision inspection, and MES connectivity. This directory organises verified automation vendors by industry vertical, so you can find partners with proven experience in your specific manufacturing environment rather than generalist suppliers with no sector depth.";

// Build breadcrumbs
const breadcrumbs = [
  { label: "Home", href: "/en/" },
  { label: "Industries", href: "/en/industries" },
];

---

<BaseLayout 
  title="Industrial Automation Industries | Automation List"
  description={description}
  lang="en"
  breadcrumbs={breadcrumbs}
>
  <IndustryGrid title="Browse by Industry" description={description} industries={industries} lang="en" headingLevel="h1" />
</BaseLayout>

