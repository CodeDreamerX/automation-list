---
// Server-Side Rendering (SSR) - This page is rendered on-demand
// See STATIC_GENERATION_STRATEGY.md for details

export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import VendorCard from "../../../components/VendorCard.astro";
import Pagination from "../../../components/Pagination.astro";
import CategoryCard from "../../../components/CategoryCard.astro";
import CollapsibleIntro from "../../../components/CollapsibleIntro.astro";
import VendorFilter from "../../../components/VendorFilter.astro";
import TopCountries from "../../../components/TopCountries.astro";
import { supabase } from "../../../lib/supabaseClient";
import { getCached, setCached } from "../../../lib/cache";
import { normalizeVendors } from "../../../lib/vendors/vendorUtils";
import { getCountryNameMap, slugifyCountry, normalizeCountryName } from "../../../lib/countryUtils";
import { linkifyText } from "../../../lib/linkify";
import { buildPageKeywordMap } from "../../../lib/keyword-map";
import type { CategoryBasic } from "../../../types/category";


// Get category slug from URL param
const categorySlug = Astro.params.slug || '';

// If no category slug, redirect to vendors page
if (!categorySlug) {
  return Astro.redirect('/en/vendors');
}

// Fetch category from database
const { data: category, error: categoryError } = await supabase
  .from('categories')
  .select('id, slug, name_en, name_de, description_en, description_de, faq_en, faq_de, meta_description_en, meta_description_de')
  .eq('slug', categorySlug)
  .eq('is_active', true)
  .maybeSingle();

if (categoryError) {
  console.error('Error fetching category:', categoryError);
}

// If category not found, redirect to vendors page
if (!category) {
  return Astro.redirect('/en/vendors');
}

const categoryId = category.id;
const categoryName = category.name_en || category.name_de || categorySlug;
const categoryDescription = category.description_en || category.description_de || '';
const countryNameMap = await getCountryNameMap(supabase, getCached, setCached);

// Split description into paragraphs (split on blank lines)
const descriptionText = category.description_en || category.description_de || '';
const descriptionParagraphs = descriptionText ? descriptionText.split(/\n\s*\n/).filter((p: string) => p.trim()) : [];

// Get pagination params
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));
const pageSize = 102;

// Build cache key
const cacheKey = `vendors:category:en:${categorySlug}:${pageSize}:${page}:v3`;

// Try to get cached result
interface CachedCategoryResult {
  vendors: any[];
  totalVendors: number;
}

let cachedResult = getCached<CachedCategoryResult>(cacheKey);
let vendors: any[] = [];
let totalVendors = 0;
let vendorIdsForPage: number[] = [];

if (cachedResult) {
  vendors = cachedResult.vendors;
  totalVendors = cachedResult.totalVendors;
  vendorIdsForPage = getCached<number[]>(`vendor_categories:category:${categoryId}`) || [];
} else {
  // First, get vendor IDs that have this category
  const categoryLinksCacheKey = `vendor_categories:category:${categoryId}`;
  let vendorIds: number[] = getCached<number[]>(categoryLinksCacheKey) || [];
  
  if (vendorIds.length === 0) {
    const { data: vendorCategoryLinks, error: linkError } = await supabase
      .from('vendor_categories')
      .select('vendor_id')
      .eq('category_id', categoryId);

    if (linkError) {
      console.error('Error fetching vendor-category links:', linkError);
      vendorIds = [];
    } else {
      vendorIds = (vendorCategoryLinks || []).map(link => link.vendor_id);
      setCached(categoryLinksCacheKey, vendorIds, 300);
      vendorIdsForPage = vendorIds;
    }
  }

  if (vendorIds.length > 0) {
    // Build query for vendors filtered by IDs
    function buildCategoryQuery() {
      return supabase
        .from('vendors')
        .select(`
          *,
          vendor_categories (
            is_primary,
            categories:categories (
              id,
              slug,
              name_en,
              name_de
            )
          ),
          vendor_countries (
            countries:countries (
              id,
              slug,
              name_en,
              name_de,
              flag_emoji
            )
          ),
          vendor_industries (
            industries:industries (
              id,
              slug,
              name_en,
              name_de
            )
          ),
          vendor_technologies (
            technologies:technologies (
              id,
              slug,
              name_en,
              name_de
            )
          )
        `, { count: 'exact' })
        .in('id', vendorIds)
        .neq('plan', 'deactivated')
        // Order by profile completeness score first (higher = more complete), then alphabetically by name
        .order('profile_score', { ascending: false, nullsFirst: false })
        .order('name', { ascending: true });
    }

    // Get total count - create a separate query for counting
    let countQuery = supabase
      .from('vendors')
      .select('*', { count: 'exact', head: true })
      .in('id', vendorIds)
      .neq('plan', 'deactivated');
    
    const { count } = await countQuery;
    totalVendors = count || 0;

    // Build paginated query
    const start = (page - 1) * pageSize;
    const end = page * pageSize - 1;
    const paginatedQuery = buildCategoryQuery().range(start, end);

    // Execute paginated query
    const { data: vendorsData, error } = await paginatedQuery;
    
    if (error) {
      console.error('Error fetching vendors:', error);
      vendors = [];
    } else {
      vendors = vendorsData || [];
    }

    // Cache the result
    setCached(cacheKey, { vendors, totalVendors }, 300);
  }
}

const keywordMap = buildPageKeywordMap('en', `/en/category/${categorySlug}`);

const seenKeywords = new Set<string>();
const linkedParagraphs = descriptionParagraphs.map((p: string) =>
  linkifyText(p.trim(), keywordMap, { maxLinks: 5, firstMatchOnly: true, seenKeywords, minWordGap: 10 })
);

// Related categories by vendor co-occurrence
const relatedCacheKey = `related_categories:${categoryId}`;
let relatedCategories = getCached<CategoryBasic[]>(relatedCacheKey);

if (!relatedCategories) {
  if (vendorIdsForPage.length > 0) {
    const { data: coData } = await supabase
      .from('vendor_categories')
      .select('category_id')
      .in('vendor_id', vendorIdsForPage)
      .neq('category_id', categoryId);

    const coCountMap = new Map<string, number>();
    (coData || []).forEach((row: any) => {
      if (row.category_id) coCountMap.set(row.category_id, (coCountMap.get(row.category_id) || 0) + 1);
    });

    const MIN_SHARED_VENDORS = 2;
    const topIds = [...coCountMap.entries()]
      .filter(([, count]) => count >= MIN_SHARED_VENDORS)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 4)
      .map(([id]) => id);

    if (topIds.length > 0) {
      const { data: relCatData } = await supabase
        .from('categories')
        .select('id, slug, name_en, name_de, card_description_en, card_description_de, icon_name')
        .in('id', topIds)
        .eq('is_active', true);

      relatedCategories = topIds
        .map(id => (relCatData || []).find((c: any) => c.id === id))
        .filter(Boolean) as CategoryBasic[];
    } else {
      relatedCategories = [];
    }
  } else {
    relatedCategories = [];
  }
  setCached(relatedCacheKey, relatedCategories, 3600);
}

// Normalize category data shape
const normalizedVendors = normalizeVendors(vendors || [], {
  includeCategories: true,
  includeIndustries: true,
  includeTechnologies: true,
  includeCountries: true,
});

const totalPages = Math.ceil((totalVendors || 0) / pageSize);

// Build filterData for VendorFilter
const filterCountryMap = new Map<string, string>();
const filterIndustryMap = new Map<string, string>();
const filterTechnologyMap = new Map<string, string>();
for (const v of normalizedVendors) {
  if (v.country) {
    const slug = slugifyCountry(v.country);
    if (slug && !filterCountryMap.has(slug)) {
      const entry = countryNameMap[normalizeCountryName(v.country)];
      filterCountryMap.set(slug, entry?.name_en || v.country);
    }
  }
  v.vendor_industries?.forEach((vi: any) => {
    if (vi.industries?.slug) filterIndustryMap.set(vi.industries.slug, vi.industries.name_en || vi.industries.slug);
  });
  v.vendor_technologies?.forEach((vt: any) => {
    if (vt.technologies?.slug) filterTechnologyMap.set(vt.technologies.slug, vt.technologies.name_en || vt.technologies.slug);
  });
}
const filterData = {
  country:    [...filterCountryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
  industry:   [...filterIndustryMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
  technology: [...filterTechnologyMap.entries()].map(([slug, label]) => ({ slug, label })).sort((a, b) => a.label.localeCompare(b.label)),
};

// FAQ
const faqItems = ((category.faq_en ?? []) as any[]).filter(
  (item: any) => item?.question?.trim() && item?.answer?.trim()
);
const hasFaq = faqItems.length > 0;
const linkedFaqItems = faqItems.map((item: any) => ({
  ...item,
  linkedAnswer: linkifyText(item.answer, keywordMap, { maxLinks: 1, firstMatchOnly: true, seenKeywords, minWordGap: 10 }),
}));

// SEO test (2026-03-31): custom meta title + H1/eyebrow for System Integrators category only
const isSystemIntegratorSeoTest = (category.slug || "").trim() === "system-integrator";

// SEO metadata
const metaTitle = isSystemIntegratorSeoTest
  ? "Top Industrial Automation System Integrators in Europe (2026)"
  : totalVendors
    ? `${totalVendors} ${categoryName} | Automation List`
    : `${categoryName} | Automation List`;
const customMetaDescription = category.meta_description_en || category.meta_description_de;
const metaDescription = (customMetaDescription && customMetaDescription.trim())
  || (totalVendors
    ? `Browse ${totalVendors} verified ${categoryName} vendors worldwide — system integrators, specialists and more. Filter by country and industry.`
    : `Browse verified ${categoryName} vendors worldwide — system integrators, specialists and more. Filter by country and industry.`);
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const defaultOg = `${siteOrigin}/og/default.png`;
const currentUrl = `${siteOrigin}/en/category/${categorySlug}`;

// Build breadcrumbs
const breadcrumbs = [
  { label: "Home", href: "/en/" },
  { label: "Categories", href: "/en/categories" },
  { label: categoryName, href: `/en/category/${categorySlug}` },
];

---

<BaseLayout 
  title={metaTitle}
  description={metaDescription}
  canonical={currentUrl}
  ogImage={defaultOg}
  lang="en"
  breadcrumbs={breadcrumbs}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `Industrial Automation ${categoryName}`,
    "description": metaDescription,
    "itemListElement": normalizedVendors.map((v, index) => ({
      "@type": "Organization",
      "position": index + 1,
      "name": v.name,
      "url": `${siteOrigin}/en/vendor/${v.slug}`,
      "logo": v.logo_url,
      "image": v.logo_url,
      "address": v.country
    }))
  })} />
  {hasFaq && (
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item: any) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer }
      }))
    })} />
  )}
  <div class="container-px mx-auto max-w-7xl px-4 py-10">
    <div class="mb-8">
      {isSystemIntegratorSeoTest ? (
        <div>
          <span class="text-sm text-gray-500 block mb-1">System Integrators</span>
          <h1 class="text-3xl font-bold text-gray-900">Industrial Automation System Integrators</h1>
        </div>
      ) : (
        <h1 class="text-3xl font-bold text-gray-900">{categoryName}</h1>
      )}
    </div>

    {linkedParagraphs.length > 0 && (
      <div class="mb-6">
        <CollapsibleIntro locale="en">
          {linkedParagraphs.map((html: string) => (
            <p class="mb-4 text-gray-700 leading-relaxed" set:html={html}></p>
          ))}
        </CollapsibleIntro>
        <a
          href="/en/vendors"
          class="mt-2 inline-flex items-center gap-1 rounded-md border border-brand-200/80 bg-brand-50 px-3.5 py-2 text-sm font-bold text-brand-800 shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-100 hover:text-brand-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
        >
          Browse all vendors →
        </a>
      </div>
    )}

    {normalizedVendors.length > 0 && (
      <VendorFilter filters={['country', 'industry', 'technology']} lang="en" filterData={filterData} totalVendors={totalVendors || 0} />
    )}

    <!-- Vendor Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {normalizedVendors.length > 0 ? (
        normalizedVendors.map(vendor => (
          <VendorCard
            vendor={vendor}
            hrefPrefix="/en/vendor"
            lang="en"
            countryNameMap={countryNameMap}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-gray-600">
            No vendors found in this category.
          </p>
        </div>
      )}
    </div>

    <TopCountries vendors={normalizedVendors} lang="en" countryNameMap={countryNameMap} />

    <!-- Pagination -->
    <Pagination
      currentPage={page}
      totalPages={totalPages}
      baseUrl={Astro.url}
      lang="en"
    />
  </div>

  {hasFaq && (
    <div class="container-px mx-auto max-w-7xl px-4 py-10 border-t border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {linkedFaqItems.map((item: any) => (
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.question}</h3>
            <p class="text-gray-700 leading-relaxed" set:html={item.linkedAnswer}></p>
          </div>
        ))}
      </div>
    </div>
  )}

  {relatedCategories && relatedCategories.length > 0 && (
    <div class="container-px mx-auto max-w-7xl px-4 py-10 border-t border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Categories</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {relatedCategories.map((cat, i) => (
          <CategoryCard category={cat} lang="en" index={i} />
        ))}
      </div>
    </div>
  )}
</BaseLayout>

