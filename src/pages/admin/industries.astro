
---
export const prerender = false;

import { supabaseAdmin } from '../../lib/supabaseAdminClient';
import { protectAdminRoute } from '../../lib/admin/authUtils';
import AdminLayout from '../../components/admin/AdminLayout.astro';
import LucideIcon from '../../components/LucideIcon.astro';

// Check authentication and redirect if not logged in
const redirectResponse = await protectAdminRoute(Astro.locals);
if (redirectResponse) {
  return redirectResponse;
}

// Fetch all industries from Supabase
const { data: industries, error } = await supabaseAdmin
  .from('industries')
  .select('id, slug, name_en, name_de, description_en, description_de, icon_name, order_index, is_active')
  .order('order_index', { ascending: true, nullsFirst: false })
  .order('name_en', { ascending: true });

if (error) {
  console.error('Error fetching industries:', error);
}

// Fetch vendor counts per industry
const { data: industryLinks } = await supabaseAdmin
  .from('vendor_industries')
  .select('industry_id');

const industryVendorCounts = new Map<string, number>();
for (const row of industryLinks || []) {
  industryVendorCounts.set(row.industry_id, (industryVendorCounts.get(row.industry_id) || 0) + 1);
}

---

<AdminLayout title="Industry Management - Admin Panel" currentPath="/admin/industries">
  <div class="space-y-6">
    <!-- HEADER -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Industry Management</h1>
        <p class="mt-1 text-sm text-gray-600">
          Manage all industries in the Automation List directory
        </p>
      </div>
      <div class="flex items-center gap-4">
        <div class="text-sm text-gray-600">
          Total: {industries?.length || 0} industries
        </div>
        <a
          href="/admin/industries/new"
          class="px-4 py-2 bg-black text-white rounded-md hover:bg-gray-900 transition-colors text-sm font-medium"
        >
          + New Industry
        </a>
      </div>
    </div>

    <!-- INDUSTRIES TABLE -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Icon
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Name
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Slug
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Order
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Active
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Vendors
              </th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {industries && industries.length > 0 ? (
              industries.map((industry) => {
                const displayName = industry.name_en || industry.name_de || '-';
                
                return (
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center justify-center w-8 h-8 text-gray-700">
                        <LucideIcon name={industry.icon_name} size={20} />
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <div class="text-sm font-medium text-gray-900">{displayName}</div>
                      {industry.name_en && industry.name_de && (
                        <div class="text-xs text-gray-500">{industry.name_de}</div>
                      )}
                      {industry.description_en && (
                        <div class="text-xs text-gray-400 mt-1">{industry.description_en.substring(0, 60)}{industry.description_en.length > 60 ? '...' : ''}</div>
                      )}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">{industry.slug || '-'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">{industry.order_index ?? '-'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">
                        {industry.is_active ? (
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Active
                          </span>
                        ) : (
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                            Inactive
                          </span>
                        )}
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">{industryVendorCounts.get(industry.id) ?? 0}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                      <div class="flex items-center justify-end gap-2">
                        <a
                          href={`/admin/industries/edit/${industry.id}`}
                          class="text-black hover:text-gray-700 px-3 py-1 rounded-md hover:bg-gray-100 transition-colors"
                        >
                          Edit
                        </a>
                        <button
                          type="button"
                          class="text-red-600 hover:text-red-800 px-3 py-1 rounded-md hover:bg-red-50 transition-colors"
                          data-delete-industry-id={industry.id}
                          data-delete-industry-name={displayName}
                        >
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })
            ) : (
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500">
                  No industries found.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    import { initAdminDeleteButtons } from '../../components/admin/admin-delete';

    initAdminDeleteButtons({
      buttonSelector: '[data-delete-industry-id]',
      idAttribute: 'data-delete-industry-id',
      nameAttribute: 'data-delete-industry-name',
      endpoint: '/api/admin/delete-industry',
      entityFallbackName: 'this industry',
      errorFallbackMessage: 'Failed to delete industry',
    });
  </script>
</AdminLayout>
