
---
export const prerender = false;

import { supabaseAdmin } from '../../lib/supabaseAdminClient';
import { protectAdminRoute } from '../../lib/admin/authUtils';
import AdminLayout from '../../components/admin/AdminLayout.astro';
import LucideIcon from '../../components/LucideIcon.astro';
import { VENDOR_THRESHOLD } from '../../lib/categoryStatus';

const redirectResponse = await protectAdminRoute(Astro.locals);
if (redirectResponse) {
  return redirectResponse;
}

// Fetch all industries including new status fields
const { data: industriesRaw, error } = await supabaseAdmin
  .from('industries')
  .select('id, slug, name_en, name_de, description_en, icon_name, order_index, is_active, status, force_active')
  .order('order_index', { ascending: true, nullsFirst: false })
  .order('name_en', { ascending: true });

if (error) {
  console.error('Error fetching industries:', error);
}

// Fetch vendor counts per industry
const { data: industryLinks } = await supabaseAdmin
  .from('vendor_industries')
  .select('industry_id');

const industryVendorCounts = new Map<string, number>();
for (const row of industryLinks || []) {
  industryVendorCounts.set(row.industry_id, (industryVendorCounts.get(row.industry_id) || 0) + 1);
}

// Sort: active first, then by vendor count desc, then name
const industries = (industriesRaw || []).slice().sort((a, b) => {
  const aActive = a.is_active ? 1 : 0;
  const bActive = b.is_active ? 1 : 0;
  if (bActive !== aActive) return bActive - aActive;
  const aCount = industryVendorCounts.get(a.id) ?? 0;
  const bCount = industryVendorCounts.get(b.id) ?? 0;
  if (bCount !== aCount) return bCount - aCount;
  return (a.name_en || '').localeCompare(b.name_en || '');
});
---

<AdminLayout title="Industry Management - Admin Panel" currentPath="/admin/industries">
  <div class="space-y-6">
    <!-- HEADER -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Industry Management</h1>
        <p class="mt-1 text-sm text-gray-600">
          Industries go live automatically at {VENDOR_THRESHOLD} vendors. Use Force Active to override.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <div class="text-sm text-gray-600">
          Total: {industries.length} industries
        </div>
        <a
          href="/admin/industries/new"
          class="px-4 py-2 bg-black text-white rounded-md hover:bg-gray-900 transition-colors text-sm font-medium"
        >
          + New Industry
        </a>
      </div>
    </div>

    <!-- INDUSTRIES TABLE -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Icon
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Name
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Slug
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Status
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Vendors
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Force Active
              </th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {industries.length > 0 ? (
              industries.map((industry) => {
                const displayName = industry.name_en || industry.name_de || '-';
                const vendorCount = industryVendorCounts.get(industry.id) ?? 0;
                const progressPct = Math.min(100, Math.round((vendorCount / VENDOR_THRESHOLD) * 100));
                const effectiveStatus = industry.status ?? (industry.is_active ? 'active' : 'pending');

                return (
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center justify-center w-8 h-8 text-gray-700">
                        <LucideIcon name={industry.icon_name} size={20} />
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <div class="text-sm font-medium text-gray-900">{displayName}</div>
                      {industry.description_en && (
                        <div class="text-xs text-gray-400 mt-1">{industry.description_en.substring(0, 60)}{industry.description_en.length > 60 ? '...' : ''}</div>
                      )}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">{industry.slug || '-'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      {effectiveStatus === 'active' ? (
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          Active
                        </span>
                      ) : (
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                          Pending
                        </span>
                      )}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">{vendorCount}</div>
                      {effectiveStatus !== 'active' && (
                        <div class="mt-1 w-20">
                          <div class="h-1.5 bg-gray-200 rounded-full overflow-hidden">
                            <div
                              class="h-full bg-orange-400 rounded-full transition-all"
                              style={`width:${progressPct}%`}
                            />
                          </div>
                          <div class="text-xs text-gray-400 mt-0.5">{vendorCount}/{VENDOR_THRESHOLD}</div>
                        </div>
                      )}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <button
                        type="button"
                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2"
                        class:list={[
                          industry.force_active ? 'bg-orange-500' : 'bg-gray-200',
                        ]}
                        aria-pressed={industry.force_active ?? false}
                        data-industry-id={industry.id}
                        data-force-active={String(industry.force_active ?? false)}
                        id={`toggle-${industry.id}`}
                      >
                        <span
                          class="inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform"
                          class:list={[
                            industry.force_active ? 'translate-x-6' : 'translate-x-1',
                          ]}
                        />
                      </button>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                      <div class="flex items-center justify-end gap-2">
                        <a
                          href={`/admin/industries/edit/${industry.id}`}
                          class="text-black hover:text-gray-700 px-3 py-1 rounded-md hover:bg-gray-100 transition-colors"
                        >
                          Edit
                        </a>
                        <button
                          type="button"
                          class="text-red-600 hover:text-red-800 px-3 py-1 rounded-md hover:bg-red-50 transition-colors"
                          data-delete-industry-id={industry.id}
                          data-delete-industry-name={displayName}
                        >
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })
            ) : (
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500">
                  No industries found.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    import { initAdminDeleteButtons } from '../../components/admin/admin-delete';

    initAdminDeleteButtons({
      buttonSelector: '[data-delete-industry-id]',
      idAttribute: 'data-delete-industry-id',
      nameAttribute: 'data-delete-industry-name',
      endpoint: '/api/admin/delete-industry',
      entityFallbackName: 'this industry',
      errorFallbackMessage: 'Failed to delete industry',
    });

    // Force Active inline toggles
    document.querySelectorAll<HTMLButtonElement>('[data-industry-id][data-force-active]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.industryId!;
        const current = btn.dataset.forceActive === 'true';
        const next = !current;

        btn.disabled = true;
        try {
          const res = await fetch('/api/admin/update-industry-force-active', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, force_active: next }),
          });
          if (!res.ok) throw new Error('Request failed');

          const data = await res.json();
          const forceActive: boolean = data.force_active ?? next;
          const status: string = data.status ?? (forceActive ? 'active' : 'pending');
          const isActive: boolean = data.is_active ?? (forceActive || status === 'active');

          btn.dataset.forceActive = String(forceActive);
          btn.setAttribute('aria-pressed', String(forceActive));
          btn.classList.toggle('bg-orange-500', forceActive);
          btn.classList.toggle('bg-gray-200', !forceActive);

          const knob = btn.querySelector('span');
          if (knob) {
            knob.classList.toggle('translate-x-6', forceActive);
            knob.classList.toggle('translate-x-1', !forceActive);
          }

          // Update Status badge in the same row
          const row = btn.closest('tr');
          if (row) {
            const badge = row.querySelector<HTMLElement>('[class*="rounded-full"]');
            if (badge) {
              if (isActive) {
                badge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800';
                badge.textContent = 'Active';
              } else {
                badge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800';
                badge.textContent = 'Pending';
              }
            }
          }
        } catch (e) {
          console.error('Failed to toggle force_active:', e);
          alert('Failed to update industry. Please try again.');
        } finally {
          btn.disabled = false;
        }
      });
    });
  </script>
</AdminLayout>
