---
export const prerender = false;

import { protectAdminRoute } from '../../../../lib/admin/authUtils';
import AdminLayout from '../../../../components/admin/AdminLayout.astro';

const redirectResponse = await protectAdminRoute(Astro.locals);
if (redirectResponse) {
  return redirectResponse;
}
---

<AdminLayout title="JSON Import - Admin Panel" currentPath="/admin/vendors/json">
  <div class="space-y-6">
    <!-- HEADER -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">JSON Import</h1>
        <p class="mt-1 text-sm text-gray-600">
          Import vendors from a JSON file
        </p>
      </div>
    </div>

    <!-- WORKFLOW EXPLANATION -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">JSON Import Workflow</h2>

      <div class="space-y-6">
        <!-- Step 1: Upload -->
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-semibold text-sm">
            1
          </div>
          <div class="flex-1">
            <h3 class="text-base font-medium text-gray-900 mb-1">Upload File</h3>
            <p class="text-sm text-gray-600">
              Select and upload your JSON file containing vendor data. The file will be validated to ensure it is a valid JSON array.
            </p>
          </div>
        </div>

        <!-- Step 2: Preview -->
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-semibold text-sm">
            2
          </div>
          <div class="flex-1">
            <h3 class="text-base font-medium text-gray-900 mb-1">Preview</h3>
            <p class="text-sm text-gray-600">
              Review the parsed data from your JSON file. Check for any errors or missing information before proceeding with the import.
            </p>
          </div>
        </div>

        <!-- Step 3: Import -->
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-semibold text-sm">
            3
          </div>
          <div class="flex-1">
            <h3 class="text-base font-medium text-gray-900 mb-1">Import</h3>
            <p class="text-sm text-gray-600">
              Confirm and import the vendors into the database. You'll receive a summary of successful imports and any errors that occurred.
            </p>
          </div>
        </div>
      </div>

      <!-- ACTION BUTTON -->
      <div class="mt-8 pt-6 border-t border-gray-200">
        <a
          href="/admin/vendors/json/upload"
          class="btn-primary"
        >
          Start JSON Import
        </a>
      </div>
    </div>

    <!-- DOWNLOADS -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 space-y-3">
      <h3 class="text-sm font-semibold text-gray-900">Downloads</h3>

      <div class="flex items-start justify-between gap-4">
        <p class="text-xs text-gray-600">
          Empty template with all supported fields — fill it in to create your import file.
        </p>
        <a
          href="/api/admin/export-template"
          download="import-template.json"
          class="text-xs text-brand-600 hover:text-brand-700 font-medium whitespace-nowrap"
        >
          import-template.json
        </a>
      </div>

      <div class="flex items-start justify-between gap-4 pt-3 border-t border-gray-100">
        <p class="text-xs text-gray-600">
          Current list of valid slugs for categories, technologies, industries, certifications, and countries, plus the allowed language labels for <code class="bg-gray-100 px-1 rounded">languages</code>.
        </p>
        <a
          href="/api/admin/export-slugs"
          download="slug-reference.json"
          class="text-xs text-brand-600 hover:text-brand-700 font-medium whitespace-nowrap"
        >
          slug-reference.json
        </a>
      </div>

      <div class="flex items-start justify-between gap-4 pt-3 border-t border-gray-100">
        <p class="text-xs text-gray-600">
          Current list of vendor names and website URLs.
        </p>
        <a
          href="/api/admin/export-vendor-urls"
          download="vendor-name-url-reference.json"
          class="text-xs text-brand-600 hover:text-brand-700 font-medium whitespace-nowrap"
        >
          vendor-name-url-reference.json
        </a>
      </div>
    </div>

    <!-- ADDITIONAL INFO -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
      <h3 class="text-sm font-semibold text-gray-900 mb-2">File Format</h3>
      <ul class="text-xs text-gray-600 space-y-1">
        <li>• File must be a JSON array of vendor objects (<code class="bg-gray-100 px-1 rounded">[{`{ ... }, { ... }`}]</code>)</li>
        <li>• Required fields per vendor: <code class="bg-gray-100 px-1 rounded">name</code>, <code class="bg-gray-100 px-1 rounded">slug</code>, <code class="bg-gray-100 px-1 rounded">country</code>, <code class="bg-gray-100 px-1 rounded">category_slugs</code></li>
        <li>• <code class="bg-gray-100 px-1 rounded">country</code> is matched to the canonical English name from your database (case-insensitive; you may use the country slug or English/German name)</li>
        <li>• Array fields (<code class="bg-gray-100 px-1 rounded">category_slugs</code>, <code class="bg-gray-100 px-1 rounded">technology_slugs</code>, <code class="bg-gray-100 px-1 rounded">industry_slugs</code>, <code class="bg-gray-100 px-1 rounded">certification_slugs</code>, <code class="bg-gray-100 px-1 rounded">country_slugs</code>, <code class="bg-gray-100 px-1 rounded">languages</code>) must be native JSON arrays</li>
        <li>• Maximum file size: 10MB</li>
        <li>• Duplicate slugs (already in the database) are skipped automatically</li>
      </ul>
    </div>
  </div>
</AdminLayout>
