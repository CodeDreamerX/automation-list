---
export const prerender = false;

import { supabaseAdmin } from '../../../lib/supabaseAdminClient';
import { protectAdminRoute } from '../../../lib/admin/authUtils';
import AdminLayout from '../../../components/admin/AdminLayout.astro';

const redirectResponse = await protectAdminRoute(Astro.locals);
if (redirectResponse) return redirectResponse;

const tab = Astro.url.searchParams.get('tab') === 'rejected' ? 'rejected' : 'pending';

const { data: pending } = await supabaseAdmin
  .from('pending_listings')
  .select('id, name, country, email, website, created_at, is_suspect')
  .eq('status', 'pending')
  .order('created_at', { ascending: false });

const { data: rejected } = await supabaseAdmin
  .from('pending_listings')
  .select('id, name, country, email, website, created_at, is_suspect, reject_reason')
  .eq('status', 'rejected')
  .order('created_at', { ascending: false });

const pendingList  = pending  || [];
const rejectedList = rejected || [];
const activeList   = tab === 'rejected' ? rejectedList : pendingList;

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<AdminLayout title="Listing Submissions — Admin" currentPath="/admin/listings">
  <div class="space-y-6" data-listings-page data-active-tab={tab}>

    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Listing Submissions</h1>
        <p class="mt-1 text-sm text-gray-600">Review and approve company submissions from the public form</p>
      </div>
    </div>

    <div id="bulk-action-banner" class="hidden px-4 py-3 rounded-lg text-sm font-medium"></div>

    {activeList.length > 0 && (
      <div class="hidden items-center justify-between gap-4 rounded-lg border border-gray-200 bg-white px-4 py-3" data-bulk-actions>
        <div class="text-sm text-gray-600">
          <span class="font-semibold text-gray-900" data-selected-count>0 selected</span>
          <span class="ml-1">
            {tab === 'rejected'
              ? 'These submissions will be permanently deleted.'
              : 'These submissions will be marked as rejected.'}
          </span>
        </div>
        <button
          type="button"
          class={`inline-flex items-center rounded-md px-4 py-2 text-sm font-medium text-white transition-colors ${
            tab === 'rejected'
              ? 'bg-red-600 hover:bg-red-700'
              : 'bg-amber-600 hover:bg-amber-700'
          }`}
          data-bulk-action-button
        >
          {tab === 'rejected' ? 'Delete selected' : 'Reject selected'}
        </button>
      </div>
    )}

    <!-- Tabs -->
    <div class="flex gap-1 border-b border-gray-200">
      <a
        href="/admin/listings"
        class={`px-4 py-2 text-sm font-medium border-b-2 transition-colors ${
          tab === 'pending'
            ? 'border-gray-900 text-gray-900'
            : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
        }`}
      >
        Pending
        <span class={`ml-1.5 px-1.5 py-0.5 rounded-full text-xs font-semibold ${
          tab === 'pending' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600'
        }`}>
          {pendingList.length}
        </span>
      </a>
      <a
        href="/admin/listings?tab=rejected"
        class={`px-4 py-2 text-sm font-medium border-b-2 transition-colors ${
          tab === 'rejected'
            ? 'border-gray-900 text-gray-900'
            : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
        }`}
      >
        Rejected
        <span class={`ml-1.5 px-1.5 py-0.5 rounded-full text-xs font-semibold ${
          tab === 'rejected' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600'
        }`}>
          {rejectedList.length}
        </span>
      </a>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      {activeList.length === 0 ? (
        <div class="px-6 py-12 text-center text-sm text-gray-400">
          No {tab} submissions.
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="w-12 px-4 py-3 text-left">
                <input
                  type="checkbox"
                  aria-label="Select all visible submissions"
                  class="h-4 w-4 rounded border-gray-300 text-gray-900 focus:ring-gray-400"
                  data-select-all
                />
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Company</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Country</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Email</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Website</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Submitted</th>
              {tab === 'rejected' && (
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Reason</th>
              )}
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {activeList.map((row: any) => (
              <tr
                class={`hover:bg-gray-50 transition-colors cursor-pointer ${
                  row.is_suspect ? 'bg-amber-50 hover:bg-amber-100' : ''
                }`}
                onclick={`window.location='/admin/listings/${row.id}'`}
              >
                <td class="px-4 py-3" onclick="event.stopPropagation()">
                  <input
                    type="checkbox"
                    value={row.id}
                    aria-label={`Select ${row.name}`}
                    class="h-4 w-4 rounded border-gray-300 text-gray-900 focus:ring-gray-400"
                    data-listing-checkbox
                  />
                </td>
                <td class="px-4 py-3 font-medium text-gray-900">
                  <span class="flex items-center gap-2">
                    {row.name}
                    {row.is_suspect && (
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-200 text-amber-800" title="Honeypot triggered — possible bot submission">
                        ⚠ Suspect
                      </span>
                    )}
                  </span>
                </td>
                <td class="px-4 py-3 text-gray-600">{row.country}</td>
                <td class="px-4 py-3 text-gray-600">{row.email}</td>
                <td class="px-4 py-3">
                  <a
                    href={row.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-600 hover:underline truncate max-w-[180px] block"
                    onclick="event.stopPropagation()"
                  >
                    {row.website?.replace(/^https?:\/\//, '')}
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">{fmtDate(row.created_at)}</td>
                {tab === 'rejected' && (
                  <td class="px-4 py-3 text-gray-500 text-xs max-w-[200px] truncate" title={row.reject_reason || ''}>
                    {row.reject_reason || '—'}
                  </td>
                )}
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

  </div>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var page = document.querySelector('[data-listings-page]');
    if (!page) return;

    var activeTab = page.getAttribute('data-active-tab') || 'pending';
    var bulkActions = page.querySelector('[data-bulk-actions]');
    var bulkActionButton = page.querySelector('[data-bulk-action-button]');
    var selectedCount = page.querySelector('[data-selected-count]');
    var selectAll = page.querySelector('[data-select-all]');
    var banner = document.getElementById('bulk-action-banner');
    var checkboxes = Array.from(page.querySelectorAll('[data-listing-checkbox]'));

    if (!bulkActions || !bulkActionButton || !selectedCount || !selectAll || checkboxes.length === 0) {
      return;
    }

    function showBanner(message) {
      if (!banner) return;
      banner.textContent = message;
      banner.className = 'px-4 py-3 rounded-lg text-sm font-medium bg-red-50 border border-red-200 text-red-700';
      banner.classList.remove('hidden');
      banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function getSelectedIds() {
      return checkboxes
        .filter(function (checkbox) { return checkbox.checked; })
        .map(function (checkbox) { return checkbox.value; });
    }

    function syncUI() {
      var count = getSelectedIds().length;
      selectedCount.textContent = count + ' selected';
      bulkActions.classList.toggle('hidden', count === 0);
      bulkActions.classList.toggle('flex', count > 0);
      selectAll.checked = count > 0 && count === checkboxes.length;
      selectAll.indeterminate = count > 0 && count < checkboxes.length;
    }

    selectAll.addEventListener('click', function (event) {
      event.stopPropagation();
    });

    selectAll.addEventListener('change', function () {
      checkboxes.forEach(function (checkbox) {
        checkbox.checked = selectAll.checked;
      });
      syncUI();
    });

    checkboxes.forEach(function (checkbox) {
      checkbox.addEventListener('click', function (event) {
        event.stopPropagation();
      });
      checkbox.addEventListener('change', syncUI);
    });

    bulkActionButton.addEventListener('click', async function () {
      var ids = getSelectedIds();
      if (ids.length === 0) return;

      var isDelete = activeTab === 'rejected';
      var confirmMessage = isDelete
        ? 'Permanently delete ' + ids.length + ' rejected submission(s)? This cannot be undone.'
        : 'Reject ' + ids.length + ' pending submission(s)?';

      if (!confirm(confirmMessage)) return;

      var originalText = bulkActionButton.textContent;
      bulkActionButton.disabled = true;
      bulkActionButton.textContent = isDelete ? 'Deleting...' : 'Rejecting...';

      try {
        var response = await fetch(
          isDelete ? '/api/admin/bulk-delete-listings' : '/api/admin/bulk-reject-listings',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: ids }),
          }
        );

        var data = await response.json();
        if (!response.ok || data.error) {
          showBanner(data.error || 'Bulk action failed. Please try again.');
          bulkActionButton.disabled = false;
          bulkActionButton.textContent = originalText;
          return;
        }

        window.location.href = isDelete ? '/admin/listings?tab=rejected' : '/admin/listings';
      } catch {
        showBanner('Network error. Please try again.');
        bulkActionButton.disabled = false;
        bulkActionButton.textContent = originalText;
      }
    });

    syncUI();
  });
</script>
