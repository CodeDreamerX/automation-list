---
import { isFeatured } from '../lib/isFeatured';
import type { VendorWithRelations, VendorCategoryRelation, VendorCountryRelation, VendorTechnologyRelation } from '../types/vendor';
import LogoBox from './LogoBox.astro';
import type { CountryNameEntry } from '../lib/countryUtils';
import { normalizeCountryName, slugifyCountry } from '../lib/countryUtils';

interface VendorCardProps {
  vendor: VendorWithRelations;
  hrefPrefix?: string;
  showFeaturedBadge?: boolean;
  compact?: boolean;
  lang?: "en" | "de";
  countryNameMap?: Record<string, CountryNameEntry>;
}

const {
  vendor,
  hrefPrefix = "/en/vendor",
  showFeaturedBadge = true,
  compact = false,
  lang = "en",
  countryNameMap = {},
} = Astro.props;

function getVendorDescription(vendor: VendorWithRelations, lang: "en" | "de"): string | null {
  if (lang === "de") {
    return vendor.description_de || vendor.description_en || null;
  }
  return vendor.description_en || null;
}

function getCountryFlag(_country: string | null | undefined): string {
  return '';
}

function getDisplayCountry(vendor: VendorWithRelations, lang: "en" | "de"): string | null {
  if (!vendor.country) return null;

  const normalizedVendorCountry = normalizeCountryName(vendor.country);
  const mappedCountry = countryNameMap[normalizedVendorCountry];
  if (mappedCountry) {
    return lang === "de"
      ? (mappedCountry.name_de || mappedCountry.name_en || vendor.country)
      : (mappedCountry.name_en || mappedCountry.name_de || vendor.country);
  }

  const matchedCountry = vendor.vendor_countries?.find((relation: VendorCountryRelation) => {
    const nameEn = relation.countries?.name_en ? normalizeCountryName(relation.countries.name_en) : '';
    const nameDe = relation.countries?.name_de ? normalizeCountryName(relation.countries.name_de) : '';
    return nameEn === normalizedVendorCountry || nameDe === normalizedVendorCountry;
  })?.countries;

  if (!matchedCountry) return vendor.country;

  return lang === "de"
    ? (matchedCountry.name_de || matchedCountry.name_en || vendor.country)
    : (matchedCountry.name_en || matchedCountry.name_de || vendor.country);
}

function getCategoryName(category: VendorCategoryRelation | null | undefined, lang: "en" | "de"): string | null {
  if (!category?.categories) return null;

  return lang === "de"
    ? (category.categories.name_de || category.categories.name_en || null)
    : (category.categories.name_en || category.categories.name_de || null);
}

function getTechnologyName(technology: VendorTechnologyRelation | null | undefined, lang: "en" | "de"): string | null {
  if (!technology?.technologies) return null;

  return lang === "de"
    ? (technology.technologies.name_de || technology.technologies.name_en || null)
    : (technology.technologies.name_en || technology.technologies.name_de || null);
}

function getBestBadges(vendor: VendorWithRelations, lang: "en" | "de"): string[] {
  const badges: string[] = [];

  const primaryCategory =
    vendor.vendor_categories?.find((category: VendorCategoryRelation) => category.is_primary === true) ||
    vendor.vendor_categories?.[0];
  const primaryCategoryName = getCategoryName(primaryCategory, lang);
  if (primaryCategoryName) {
    badges.push(primaryCategoryName);
  }

  const secondaryCategory = vendor.vendor_categories?.find((category: VendorCategoryRelation) => {
    const categoryName = getCategoryName(category, lang);
    return category !== primaryCategory && !!categoryName && categoryName !== primaryCategoryName;
  });
  const secondaryCategoryName = getCategoryName(secondaryCategory, lang);
  if (secondaryCategoryName) {
    badges.push(secondaryCategoryName);
  }

  const firstTechnologyName = (vendor.vendor_technologies || [])
    .map((technology: VendorTechnologyRelation) => getTechnologyName(technology, lang))
    .find(Boolean);

  if (!secondaryCategoryName && firstTechnologyName && !badges.includes(firstTechnologyName)) {
    badges.push(firstTechnologyName);
  }

  const countryName = getDisplayCountry(vendor, lang);
  const countryBadge = countryName ? `${getCountryFlag(vendor.country)} ${countryName}`.trim() : null;
  if (countryBadge && !badges.includes(countryBadge)) {
    badges.push(countryBadge);
  } else if (firstTechnologyName && !badges.includes(firstTechnologyName)) {
    badges.push(firstTechnologyName);
  }

  return badges.slice(0, 3);
}

function parseLogoVariant(logoUrl: string | null | undefined): "light" | "dark" | "neutral" | "brand" {
  if (!logoUrl) return "light";

  const url = logoUrl.toLowerCase();

  const explicitVariantMatch = url.match(/__([a-z]+)\.(svg|png|jpg|jpeg|webp)$/);
  if (explicitVariantMatch) {
    const variant = explicitVariantMatch[1];
    const variantMap: Record<string, "light" | "dark" | "neutral" | "brand"> = {
      white: 'light',
      light: 'neutral',
      gray: 'neutral',
      dark: 'dark',
      brand: 'brand',
    };
    if (variantMap[variant]) {
      return variantMap[variant];
    }
  }

  if (url.includes('_white') || url.includes('-white') || url.match(/white[._-]/)) {
    return 'dark';
  }

  if (url.includes('_dark') || url.includes('-dark') || url.includes('_black') || url.includes('-black')) {
    return 'light';
  }

  return 'light';
}

function getLogoVariant(vendor: VendorWithRelations): "light" | "dark" | "neutral" | "brand" {
  const storedVariant = (vendor as any).logo_background_variant;
  if (storedVariant && typeof storedVariant === 'string') {
    const validVariants: ("light" | "dark" | "neutral" | "brand")[] = ['light', 'dark', 'neutral', 'brand'];
    if (validVariants.includes(storedVariant as any)) {
      return storedVariant as "light" | "dark" | "neutral" | "brand";
    }
  }

  return parseLogoVariant(vendor.logo_url);
}

const vendorHref = `${hrefPrefix}/${vendor.slug}`;
const vendorIsFeatured = isFeatured(vendor);
const vendorIsPro = vendor.plan === 'pro' || vendorIsFeatured;
const vendorDescription = getVendorDescription(vendor, lang);
const badgeLabels = getBestBadges(vendor, lang);
---

<a
  href={vendorHref}
  data-country={slugifyCountry(vendor.country || '')}
  data-category={vendor.category_slugs?.join(',') || ''}
  data-industry={vendor.industry_slugs?.join(',') || ''}
  data-technology={vendor.technology_slugs?.join(',') || ''}
  class="block h-full group focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-lg"
  aria-label={`${vendor.name} - ${lang === "de" ? "Profil anzeigen" : "View Profile"}`}
>
  <div
    class={`relative h-full bg-white rounded-lg border px-4 py-5 transition-all flex flex-col items-center text-center ${
      vendorIsFeatured
        ? 'bg-yellow-50/30 border-yellow-300 hover:border-yellow-400 hover:shadow-md active:bg-yellow-100/50 md:hover:bg-yellow-50/50'
        : vendorIsPro
          ? 'bg-orange-50/30 border-orange-200 hover:border-orange-300 hover:shadow-md active:bg-orange-100/40 md:hover:bg-orange-50/50'
          : 'border-gray-200 hover:border-gray-300 hover:shadow-md active:bg-gray-50 md:hover:bg-gray-50'
    }`}
  >
    <div class="mb-5 flex justify-center">
      <LogoBox
        src={vendor.logo_url}
        alt={vendor.logo_alt || `${vendor.name} logo`}
        size="md"
        variant={getLogoVariant(vendor)}
        logoWidth={vendor.logo_width}
        logoHeight={vendor.logo_height}
      />
    </div>

    <h3 class="text-lg font-semibold text-gray-900 mb-3 group-hover:text-brand-700 transition-colors">
      {vendor.name}
    </h3>

    <div class="min-h-[3rem]">
      {vendorDescription && (
        <p class="text-sm leading-6 text-gray-600 text-center line-clamp-2">
          {vendorDescription}
        </p>
      )}
    </div>

    {badgeLabels.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2 justify-center">
        {badgeLabels.map((badgeLabel, index) => (
          <span class={`text-xs px-2.5 py-1 rounded-full ${index === 0 ? 'bg-gray-200 text-gray-800 font-medium' : 'bg-gray-100 text-gray-600 font-normal'}`}>
            {badgeLabel}
          </span>
        ))}
      </div>
    )}

    <span class="mt-auto pt-6 inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-sm text-brand-700 group-hover:text-brand-800 font-semibold transition-colors">
      {lang === "de" ? "Profil anzeigen ->" : "View Profile ->"}
    </span>
  </div>
</a>
