---
interface Props {
  heading?: string;
  points?: string[];
  ctaText?: string;
  ctaHref?: string;
}

const {
  heading = "List your company. Get found by engineers.",
  points = [
    "Free permanent listing — no commission, no catch",
    "The directory ranks on Google and is cited by AI search tools like Bing Copilot",
    "Submit in 5 minutes — we review and publish manually",
  ],
  ctaText = "Add your free profile →",
  ctaHref = "/en/submit-listing",
} = Astro.props;
---

<section class="bg-gray-50 border-t border-b border-gray-200 py-12 my-4">
  <div class="container-px mx-auto max-w-7xl px-4 text-center">
    <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-6">{heading}</h2>
    <ul class="flex flex-col md:flex-row justify-center gap-6 md:gap-10 text-gray-700 text-sm mb-8 max-w-3xl mx-auto">
      {points.map((point) => (
        <li class="flex items-start gap-2 text-left md:max-w-[220px]">
          <span class="text-green-600 font-bold shrink-0 mt-0.5">✓</span>
          <span>{point}</span>
        </li>
      ))}
    </ul>
    <a
      href={ctaHref}
      class="inline-block px-6 py-3 bg-black text-white rounded-md text-sm font-medium hover:bg-gray-900 transition"
    >
      {ctaText}
    </a>
  </div>
</section>
