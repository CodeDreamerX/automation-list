---
import LucideIconPicker from './LucideIconPicker.astro';

interface IndustryFormProps {
  industry: any | null;
}

const { industry } = Astro.props;
const isNewIndustry = !industry || !industry.id;

// Determine form action URL
const formAction = isNewIndustry 
  ? '/api/admin/create-industry' 
  : '/api/admin/update-industry';
---

<form method="POST" action={formAction} class="space-y-8">
  {!isNewIndustry && industry?.id && (
    <input type="hidden" name="id" value={industry.id} />
  )}

  <!-- BASIC INFORMATION -->
  <section>
    <h2 class="text-xl font-semibold text-gray-900 mb-4 border-b pb-1">
      Basic Information
    </h2>
    
    <div>
      <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">
        Slug *
      </label>
      <input
        type="text"
        id="slug"
        name="slug"
        value={industry?.slug || ''}
        required
        class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
      />
      <p class="text-xs text-gray-500 mt-1">URL-friendly identifier</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="name_en" class="block text-sm font-medium text-gray-700 mb-1">
          Name (English) *
        </label>
        <input
          type="text"
          id="name_en"
          name="name_en"
          value={industry?.name_en || ''}
          required
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        />
      </div>
      
      <div>
        <label for="name_de" class="block text-sm font-medium text-gray-700 mb-1">
          Name (German)
        </label>
        <input
          type="text"
          id="name_de"
          name="name_de"
          value={industry?.name_de || ''}
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        />
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="description_en" class="block text-sm font-medium text-gray-700 mb-1">
          Description (English)
        </label>
        <textarea
          id="description_en"
          name="description_en"
          rows="4"
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        >{industry?.description_en || ''}</textarea>
      </div>
      
      <div>
        <label for="description_de" class="block text-sm font-medium text-gray-700 mb-1">
          Description (German)
        </label>
        <textarea
          id="description_de"
          name="description_de"
          rows="4"
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        >{industry?.description_de || ''}</textarea>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="card_description_en" class="block text-sm font-medium text-gray-700 mb-1">
          Card description (EN)
        </label>
        <input
          type="text"
          id="card_description_en"
          name="card_description_en"
          value={industry?.card_description_en || ''}
          maxlength="60"
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        />
        <p class="text-xs text-gray-500 mt-1">Short keyword line for grid cards (max ~60 chars)</p>
      </div>
      
      <div>
        <label for="card_description_de" class="block text-sm font-medium text-gray-700 mb-1">
          Card description (DE)
        </label>
        <input
          type="text"
          id="card_description_de"
          name="card_description_de"
          value={industry?.card_description_de || ''}
          maxlength="60"
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        />
        <p class="text-xs text-gray-500 mt-1">Short keyword line for grid cards (max ~60 chars)</p>
      </div>
    </div>
  </section>

  <!-- ICON SELECTION -->
  <section>
    <h2 class="text-xl font-semibold text-gray-900 mb-4 border-b pb-1">
      Icon Selection
    </h2>
    <LucideIconPicker selectedIconName={industry?.icon_name} fieldName="icon_name" />
  </section>

  <!-- SETTINGS -->
  <section>
    <h2 class="text-xl font-semibold text-gray-900 mb-4 border-b pb-1">
      Settings
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="order_index" class="block text-sm font-medium text-gray-700 mb-1">
          Order Index
        </label>
        <input
          type="number"
          id="order_index"
          name="order_index"
          value={industry?.order_index ?? ''}
          min="0"
          step="1"
          class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
        />
        <p class="text-xs text-gray-500 mt-1">Lower numbers appear first (0, 1, 2, ...)</p>
      </div>
      
      <div class="flex items-center pt-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="checkbox"
            id="is_active"
            name="is_active"
            checked={industry?.is_active !== false}
            class="w-4 h-4 text-black border-gray-300 rounded focus:ring-black"
          />
          <span class="text-sm font-medium text-gray-700">Active</span>
        </label>
        <p class="text-xs text-gray-500 ml-4">Inactive industries are hidden from public pages</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <h2 class="text-xl font-semibold text-gray-900 mb-4 border-b pb-1">
      FAQ
    </h2>

    <div class="mb-8">
      <h3 class="text-base font-medium text-gray-800 mb-3">FAQ (English)</h3>
      <div id="faq-en-rows" class="space-y-4 mb-3"></div>
      <button type="button" id="add-faq-en" class="text-sm text-orange-600 hover:text-orange-800 font-medium">+ Add Question (EN)</button>
      <input type="hidden" name="faq_en" id="faq_en_value" />
    </div>

    <div>
      <h3 class="text-base font-medium text-gray-800 mb-3">FAQ (Deutsch)</h3>
      <div id="faq-de-rows" class="space-y-4 mb-3"></div>
      <button type="button" id="add-faq-de" class="text-sm text-orange-600 hover:text-orange-800 font-medium">+ Add Question (DE)</button>
      <input type="hidden" name="faq_de" id="faq_de_value" />
    </div>
  </section>

  <!-- SUBMIT BUTTONS -->
  <div class="flex items-center justify-between pt-4 border-t">
    <a
      href="/admin/industries"
      class="px-4 py-2 bg-gray-100 text-gray-700 rounded-md hover:bg-gray-200 transition-colors text-sm font-medium"
    >
      Cancel
    </a>
    <button
      type="submit"
      class="px-6 py-3 bg-black text-white rounded-md hover:bg-gray-900 transition-colors font-medium"
    >
      {isNewIndustry ? 'Create Industry' : 'Save Changes'}
    </button>
  </div>
</form>

<script>
  import { initTitleLengthFeedback } from './title-length-feedback';
  document.addEventListener('DOMContentLoaded', () => {
    initTitleLengthFeedback(['name_en', 'name_de']);
  });
</script>

<script is:inline define:vars={{ initialFaqEn: industry?.faq_en ?? [], initialFaqDe: industry?.faq_de ?? [] }}>
  function createFaqRow(lang, question, answer) {
    const row = document.createElement('div');
    row.className = 'faq-row flex gap-3 items-start p-3 bg-gray-50 rounded-md border border-gray-200';
    row.innerHTML = `
      <div class="flex-1 space-y-2">
        <input type="text" placeholder="Question" value="${(question || '').replace(/"/g, '&quot;')}"
          class="faq-question border border-gray-300 rounded-md px-3 py-2 w-full text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent" />
        <textarea rows="3" placeholder="Answer"
          class="faq-answer border border-gray-300 rounded-md px-3 py-2 w-full text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent resize-y">${(answer || '').replace(/</g, '&lt;')}</textarea>
      </div>
      <button type="button" class="mt-1 text-red-500 hover:text-red-700 text-sm font-medium px-2 py-1 shrink-0">Remove</button>
    `;
    row.querySelector('button').addEventListener('click', () => row.remove());
    return row;
  }

  document.getElementById('add-faq-en').addEventListener('click', () => {
    document.getElementById('faq-en-rows').appendChild(createFaqRow('en', '', ''));
  });
  document.getElementById('add-faq-de').addEventListener('click', () => {
    document.getElementById('faq-de-rows').appendChild(createFaqRow('de', '', ''));
  });

  document.querySelector('form').addEventListener('submit', () => {
    const serialize = (containerId, hiddenId) => {
      const rows = document.querySelectorAll(`#${containerId} .faq-row`);
      const items = [];
      rows.forEach(row => {
        const q = row.querySelector('.faq-question').value.trim();
        const a = row.querySelector('.faq-answer').value.trim();
        if (q && a) items.push({ question: q, answer: a });
      });
      document.getElementById(hiddenId).value = items.length > 0 ? JSON.stringify(items) : '';
    };
    serialize('faq-en-rows', 'faq_en_value');
    serialize('faq-de-rows', 'faq_de_value');
  });

  (initialFaqEn || []).forEach(item => {
    document.getElementById('faq-en-rows').appendChild(createFaqRow('en', item.question, item.answer));
  });
  (initialFaqDe || []).forEach(item => {
    document.getElementById('faq-de-rows').appendChild(createFaqRow('de', item.question, item.answer));
  });
</script>


