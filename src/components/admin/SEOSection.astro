---
import FormInput from './FormInput.astro';
import FormTextarea from './FormTextarea.astro';
import FormSection from './FormSection.astro';

interface SEOSectionProps {
  vendor: any;
}

const { vendor } = Astro.props;
---

<FormSection title="SEO Metadata">
  <FormInput
    id="meta_title"
    name="meta_title"
    label="Meta Title"
    value={vendor?.meta_title || ''}
  />
  <p id="meta_title_counter" class="text-xs mt-[-0.75rem] mb-4 text-gray-500">
    0 characters
  </p>
  
  <FormTextarea
    id="meta_description"
    name="meta_description"
    label="Meta Description"
    value={vendor?.meta_description || ''}
    rows={3}
  />
  
  <FormInput
    id="canonical_url"
    name="canonical_url"
    label="Canonical URL"
    type="url"
    value={vendor?.canonical_url || ''}
  />
  
  <div>
    <label for="logo_url_manual" class="block text-sm font-medium text-gray-700 mb-1">
      Logo URL (Manual Override)
    </label>
    <input
      type="url"
      id="logo_url_manual"
      value={vendor?.logo_url || ''}
      class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
      placeholder="Or enter logo URL manually"
    />
    <p class="text-xs text-gray-500">Leave empty to use uploaded logo above</p>
  </div>
</FormSection>

<script>
  const metaTitleInput = document.getElementById('meta_title') as HTMLInputElement | null;
  const metaTitleCounter = document.getElementById('meta_title_counter');

  const updateMetaTitleCounter = () => {
    if (!metaTitleInput || !metaTitleCounter) return;

    const length = metaTitleInput.value.length;
    metaTitleCounter.textContent = `${length} characters`;
    metaTitleCounter.classList.remove('text-green-600', 'text-orange-500', 'text-red-600');

    if (length <= 60) {
      metaTitleCounter.classList.add('text-green-600');
      return;
    }

    if (length <= 65) {
      metaTitleCounter.classList.add('text-orange-500');
      return;
    }

    metaTitleCounter.classList.add('text-red-600');
  };

  if (metaTitleInput && metaTitleCounter) {
    updateMetaTitleCounter();
    metaTitleInput.addEventListener('input', updateMetaTitleCounter);
  }
</script>

