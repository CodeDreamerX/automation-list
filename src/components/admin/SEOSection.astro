---
import FormInput from './FormInput.astro';
import FormTextarea from './FormTextarea.astro';
import FormSection from './FormSection.astro';

interface SEOSectionProps {
  vendor: any;
}

const { vendor } = Astro.props;
---

<FormSection title="SEO Metadata">
  <FormInput
    id="meta_title"
    name="meta_title"
    label="Meta Title (EN)"
    value={vendor?.meta_title || ''}
  />
  <p id="meta_title_counter" class="text-xs mt-[-0.75rem] mb-4 text-gray-500">
    0 characters
  </p>

  <FormInput
    id="meta_title_de"
    name="meta_title_de"
    label="Meta Title (DE)"
    value={vendor?.meta_title_de || ''}
  />
  <p id="meta_title_de_counter" class="text-xs mt-[-0.75rem] mb-4 text-gray-500">
    0 characters
  </p>

  <FormTextarea
    id="meta_description"
    name="meta_description"
    label="Meta Description"
    value={vendor?.meta_description || ''}
    rows={3}
  />
  
  <FormInput
    id="canonical_url"
    name="canonical_url"
    label="Canonical URL"
    type="url"
    value={vendor?.canonical_url || ''}
  />
  
  <div>
    <label for="logo_url_manual" class="block text-sm font-medium text-gray-700 mb-1">
      Logo URL (Manual Override)
    </label>
    <input
      type="url"
      id="logo_url_manual"
      value={vendor?.logo_url || ''}
      class="border border-gray-300 rounded-md px-3 py-2 w-full text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
      placeholder="Or enter logo URL manually"
    />
    <p class="text-xs text-gray-500">Leave empty to use uploaded logo above</p>
  </div>
</FormSection>

<script>
  function initTitleCounter(inputId: string, counterId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const counter = document.getElementById(counterId);
    if (!input || !counter) return;

    const update = () => {
      const length = input.value.length;
      counter.textContent = `${length} characters`;
      counter.classList.remove('text-green-600', 'text-orange-500', 'text-red-600');
      if (length <= 60) {
        counter.classList.add('text-green-600');
      } else if (length <= 65) {
        counter.classList.add('text-orange-500');
      } else {
        counter.classList.add('text-red-600');
      }
    };

    update();
    input.addEventListener('input', update);
  }

  initTitleCounter('meta_title', 'meta_title_counter');
  initTitleCounter('meta_title_de', 'meta_title_de_counter');
</script>

