---
import FormInput from './FormInput.astro';
import FormSection from './FormSection.astro';
import FormTextarea from './FormTextarea.astro';

interface CompanyInfoSectionProps {
  vendor: any;
}

const { vendor } = Astro.props;
---

<FormSection title="Company Information">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <FormInput
      id="year_founded"
      name="year_founded"
      label="Year Founded"
      type="number"
      value={vendor?.year_founded || ''}
      min="1800"
      max="2100"
    />

    <FormInput
      id="employee_count"
      name="employee_count"
      label="Employee Count"
      value={vendor?.employee_count || ''}
      placeholder="e.g., 50-100"
    />

    <FormInput
      id="hourly_rate"
      name="hourly_rate"
      label="Hourly Rate"
      value={vendor?.hourly_rate || ''}
      placeholder="e.g., €50-100"
    />
  </div>

  <FormTextarea
    id="specialization_text"
    name="specialization_text"
    label="What Makes Us Different"
    value={vendor?.specialization_text || ''}
    rows={3}
  />

  <div class="flex items-center">
    <label class="flex items-center gap-2 cursor-pointer">
      <input
        type="checkbox"
        id="taking_new_projects"
        name="taking_new_projects"
        checked={vendor?.taking_new_projects === true}
        class="w-4 h-4 text-black border-gray-300 rounded focus:ring-black"
      />
      <span class="text-sm font-medium text-gray-700">Taking New Projects</span>
    </label>
  </div>
</FormSection>
