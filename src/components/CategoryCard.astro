---
import type { CategoryBasic } from '../types/category';
import LucideIcon from './LucideIcon.astro';

interface CategoryCardProps {
  category: CategoryBasic;
  lang?: string;
  index?: number;
  cardHtml?: string;
}

const {
  category,
  lang = "en",
  index = 0,
  cardHtml,
} = Astro.props;

// Get name and card description based on language
const name = lang === "de" ? category.name_de : category.name_en;

const cardText = lang === "de" ? category.card_description_de : category.card_description_en;

// Build link using slug
const link = `/${lang}/category/${category.slug}`;

---

<div
  class="fade-in-up relative bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-gray-300 transition flex flex-col items-center text-center"
  style={`animation-delay: ${index * 0.05}s`}
>
  {/* Full-card link overlay — sits below content so inner <a> tags in descriptions still work */}
  <a href={link} class="absolute inset-0 rounded-xl z-0" aria-label={name}></a>

  {category.count !== undefined && category.count > 0 && (
    <span class="absolute top-3 right-3 z-10 bg-gray-100 text-gray-700 text-xs font-medium px-2 py-0.5 rounded-full">{category.count}</span>
  )}
  {category.icon_name && (
    <div class="relative z-10 flex justify-center mb-4 text-gray-700 pointer-events-none">
      <LucideIcon name={category.icon_name} size={28} />
    </div>
  )}
  <h3 class="relative z-10 text-lg font-semibold text-gray-900 pointer-events-none">{name}</h3>
  {cardHtml ? (
    <p class="relative z-10 text-sm text-gray-600 mt-2 pointer-events-none" set:html={cardHtml}></p>
  ) : cardText?.trim() && (
    <p class="relative z-10 text-sm text-gray-600 mt-2">{cardText}</p>
  )}
</div>

