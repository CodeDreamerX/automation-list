---
import type { CountryBasic } from '../types/country';
import CountryCard from './CountryCard.astro';

interface CountryGridProps {
  title?: string;
  description?: string;
  countries: (CountryBasic & { vendor_count?: number })[];
  lang?: string;
  headingLevel?: 'h1' | 'h2';
}

const {
  title = 'Browse by Country',
  description,
  countries = [],
  lang = 'en',
  headingLevel = 'h2',
} = Astro.props as CountryGridProps;
---

{countries.length > 0 && (
  <section class="fade-in-up container-px mx-auto max-w-7xl px-4 py-16 md:py-20">
    {headingLevel === 'h1' ? (
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-10 text-center">{title}</h1>
    ) : (
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-10 text-center">{title}</h2>
    )}
    {description && (
      <p class="text-lg md:text-xl text-gray-600 mb-6 md:mb-10 text-center w-full">{description}</p>
    )}
    <slot name="belowDescription" />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {countries.map((country: CountryBasic & { vendor_count?: number }, i: number) => (
        <CountryCard country={country} lang={lang} index={i} />
      ))}
    </div>
  </section>
)}
