---
interface HowItWorksProps {
  title?: string;
  steps?: Array<{
    title: string;
    description: string;
  }>;
}

type Step = {
  title: string;
  description: string;
};

const {
  title = "No friction. Just find.",
  steps = [
    {
      title: "No account needed",
      description: "Browse every vendor, category, and technology profile without registering. No email wall, no trial, no gatekeeping.",
    },
    {
      title: "No paid placement",
      description: "Vendors appear based on profile completeness — not budget. The top result is the most complete profile, not the biggest advertiser.",
    },
    {
      title: "Profiles that actually help",
      description: "Every listing includes technology stack, industry focus, and country — not just a logo and a website link.",
    },
  ] as Step[],
} = Astro.props;
---

<section class="fade-in-up container-px mx-auto max-w-7xl px-4 py-16 md:py-20 border-t border-gray-200 mt-8 pt-8">
  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-10 text-center">{title}</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
    {steps.map((step: Step) => (
      <div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">{step.title}</h3>
        <p class="text-gray-600 text-sm">{step.description}</p>
      </div>
    ))}
  </div>
</section>

