---
interface WhyThisDirectoryProps {
  title?: string;
  description?: string;
  benefits?: string[];
}

const {
  title = "Why This Directory?",
  description = "Automation-List is a vendor-neutral directory built by automation engineers. No sponsored rankings, no agencies manipulating results — just clean, structured data.",
  benefits = [
    "Every category maps to a real discipline — MES, SCADA, DCS, Safety, Vision",
    "Built by an automation engineer with 15+ years in pharma, food, and energy",
    "No agency curation. No sponsored results. No noise.",
    "The directory you'd want to exist when you actually need a vendor.",
  ],
}: WhyThisDirectoryProps = Astro.props;
---

<section class="fade-in-up container-px mx-auto max-w-7xl px-4 py-20 md:py-24 border-t border-gray-200 mt-8">
  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-10 text-center">{title}</h2>

  <div class="max-w-2xl mx-auto text-left">
    <ul class="space-y-5 text-gray-700">
      {benefits.map((benefit) => (
        <li>✓ {benefit}</li>
      ))}
    </ul>
  </div>
</section>

